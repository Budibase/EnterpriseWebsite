---
import InstructionsEditor from "@components/InstructionsEditor.astro";

interface Props {
  collapsible?: boolean;
  collapsedHeight?: number;
}

const {
  collapsible = false,
  collapsedHeight = 200,
} = Astro.props as Props;

const promptId = `access-request-prompt-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class="rounded-[7px] p-[6px] access-request-prompt-card"
  style="border: 1px dashed var(--color-grey-800);"
  data-prompt-id={promptId}
  data-collapsible={collapsible ? "true" : "false"}
  data-collapsed-height={String(collapsedHeight)}
>
  <div class="relative">
    <div
      id={`${promptId}-content`}
      class="access-request-prompt-content"
      data-prompt-content
      style={`--access-request-collapsed-height:${String(collapsedHeight)}px;`}
    >
      <InstructionsEditor class="pt-8" background="var(--bg-2)" border="0.5px solid var(--color-grey-900)">
      <li><span class="token-heading">## Persona</span></li>
      <li>
        You are an access decision agent. Your task is to evaluate access requests <strong>strictly according to the Access Decision Policy</strong> provided to you as reference material. You do not grant or revoke access. You only produce a <strong>recommendation</strong> and <strong>policy-based reasoning</strong> for a human approver.
      </li>
      <li><span class="token-heading">### Inputs</span></li>
      <li>You will receive:</li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">requester_email</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">application</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">justification</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">'_id'</span> - the unique identifier of the relevant row on the Access Requests table.
      </li>
      <li class="is-empty"></li>
      <li><span class="token-heading">### Instructions</span></li>
      <li>1. Evaluate the request against the Access Decision Policy.</li>
      <li>2. Apply all required checks in the order defined by the policy.</li>
      <li>3. Do not invent rules, exceptions, or assumptions.</li>
      <li>4. If the request violates any policy rule, recommend denial.</li>
      <li>5. If the request satisfies all policy rules, recommend approval.</li>
      <li class="is-empty"></li>
      <li><span class="token-heading">### Actions</span></li>
      <li>
        Use <span class="token-chip">{'{{ api.okta_management.listApplications }}'}</span>to retrieve the id of the relevant Application in Okta. With <span class="token-code">YourOktaDomain</span> set to integrator-9247497-admin.okta.com
      </li>
      <li class="is-empty"></li>
      <li>
        Use <span class="token-chip">{'{{ api.okta_management.listUsers }}'}</span>to retrieve the id of the relevant user in Okta. With <span class="token-code">YourOktaDomain</span> set to integrator-9247497-admin.okta.com. The <span class="token-code">requestor_email</span> input is set to the q param.
      </li>
      <li class="is-empty"></li>
      <li>
        Based on the outcome, you must update the relevant row on the <span class="token-code">Access Requests</span> table. You must populate the following fields:
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">decision</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">reason</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">oktaApp</span> - (JSON object containing "id", "name", "label", "status")
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">OktaUser</span> - (JSON object containing "id", "first_name", "last_name", "email")
      </li>
      <li>You can retrieve this table and its schema with:</li>
      <li>
        <span class="token-chip">{'{{ budibase.list_tables }}'}</span>
        <span class="token-chip">{'{{ budibase.get_table }}'}</span>
        <span class="token-chip">{'{{ budibase.get_row }}'}</span>
      </li>
      <li>
        and update the appropriate row using <span class="token-chip">{'{{ budibase.update_row }}'}</span> using the <span class="token-code">_id</span> variable (which begins with <span class="token-code">ro_ta_</span>) you received as an input as the <span class="token-code">_id</span> field.
      </li>
      <li class="is-empty"></li>
      <li><span class="token-heading">### Output requirements</span></li>
      <li>Return <strong>only</strong> the following JSON:</li>
      <li class="is-empty"></li>
      <li><span class="token-code">{'```json'}</span></li>
      <li>{"{"}</li>
      <li>  "decision": "approve_recommended | deny_recommended",</li>
      <li>  "application": "&lt;application&gt;",</li>
      <li>  "sensitivity": "&lt;low | medium | high&gt;",</li>
      <li>  "reason": "&lt;single sentence explaining the recommendation by referencing the policy&gt;",</li>
      <li>  "oktaUser: (JSON object containing "id", "first_name", "last_name", "email")</li>
      <li>  "oktaApp": (JSON object containing "id", "name", "label")</li>
      <li>{"}"}</li>
      <li><span class="token-code">{'```'}</span></li>
      <li class="is-empty"></li>
      <li><span class="token-heading">### Logging outcomes</span></li>
      <li>
        You must log all decisions on the 'Decisions' Table. Using <span class="token-chip">{'{{ budibase.create_row }}'}</span>. You can use <span class="token-chip">{'{{ budibase.list_tables }}'}</span><span class="token-chip">{'{{ budibase.get_table }}'}</span> to retrieve the schema for this.
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">'date'</span> - the timestamp for the decision in the format - 2026-02-03T15:26:17.764Z
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">'access_request'</span> - populate with the <span class="token-code">"_id"</span> input, beginning with <span class="token-code">"ro_ta_"</span>
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">'decision'</span> - populate with the output JSON object above.
      </li>
      <li>
        <span class="token-bullet token-bullet-purple">-</span>
        <span class="token-code">'human_approver'</span> - leave null.
      </li>
    </InstructionsEditor>
      <div class="access-request-prompt-fade" data-prompt-fade></div>
    </div>
    <button
      type="button"
      class="absolute right-2 top-2 z-10 text-[13px] font-medium text-text-muted transition-colors hover:text-text"
      aria-label="Copy prompt"
      data-copy-button
    >
      Copy
    </button>
  </div>
  <div class="access-request-prompt-footer" data-prompt-footer hidden>
    <button
      type="button"
      class="access-request-prompt-toggle"
      data-prompt-toggle
      aria-controls={`${promptId}-content`}
      aria-expanded="false"
    >
      Read more
    </button>
  </div>
</div>

<style>
  .access-request-prompt-content {
    position: relative;
  }

  .access-request-prompt-card[data-collapsible="true"].is-collapsed
    .access-request-prompt-content {
    height: var(--access-request-collapsed-height);
    overflow: hidden;
  }

  .access-request-prompt-fade {
    display: none;
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 72px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--bg-2) 95%, transparent) 100%
    );
    pointer-events: none;
  }

  .access-request-prompt-card[data-collapsible="true"].is-collapsed.has-overflow
    .access-request-prompt-fade {
    display: block;
  }

  .access-request-prompt-footer {
    border-top: 0.5px solid var(--color-grey-900);
    margin-top: 0.45rem;
    padding: 0.58rem 0.9rem 0.65rem;
    display: flex;
    justify-content: center;
  }

  .access-request-prompt-toggle {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
    font-weight: 500;
    padding: 0.2rem 0.4rem;
    transition: color 0.2s ease;
  }

  .access-request-prompt-toggle:hover {
    color: var(--text-primary);
  }
</style>

<script is:inline define:vars={{ promptId }}>
  const root = document.querySelector(`[data-prompt-id="${promptId}"]`);
  const button = root?.querySelector("[data-copy-button]");
  const editor = root?.querySelector(".hero-demo-instructions-lines");
  const content = root?.querySelector("[data-prompt-content]");
  const footer = root?.querySelector("[data-prompt-footer]");
  const toggle = root?.querySelector("[data-prompt-toggle]");
  const collapsible = root?.dataset.collapsible === "true";
  const collapsedHeight = Number(root?.dataset.collapsedHeight ?? "200");

  if (root && collapsible && content && footer && toggle) {
    root.classList.add("is-collapsed");

    const setToggleState = (expanded) => {
      if (expanded) {
        root.classList.add("is-expanded");
        root.classList.remove("is-collapsed");
        toggle.textContent = "Read less";
        toggle.setAttribute("aria-expanded", "true");
      } else {
        root.classList.add("is-collapsed");
        root.classList.remove("is-expanded");
        toggle.textContent = "Read more";
        toggle.setAttribute("aria-expanded", "false");
      }
    };

    const refreshToggleVisibility = () => {
      const hasOverflow = content.scrollHeight > collapsedHeight + 1;
      root.classList.toggle("has-overflow", hasOverflow);
      footer.hidden = !hasOverflow;
      if (!hasOverflow) {
        root.classList.remove("is-collapsed", "is-expanded");
      } else if (!root.classList.contains("is-expanded")) {
        setToggleState(false);
      }
    };

    toggle.addEventListener("click", () => {
      const expanded = root.classList.contains("is-expanded");
      setToggleState(!expanded);
    });

    refreshToggleVisibility();
    window.addEventListener("resize", refreshToggleVisibility, {
      passive: true,
    });
  }

  if (button && editor) {
    button.addEventListener("click", async () => {
      const text = editor.innerText.trim();
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          const textarea = document.createElement("textarea");
          textarea.value = text;
          textarea.style.position = "fixed";
          textarea.style.opacity = "0";
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          document.execCommand("copy");
          textarea.remove();
        }
        const original = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          button.textContent = original;
        }, 1500);
      } catch (err) {
        console.error("Copy failed", err);
      }
    });
  }
</script>
