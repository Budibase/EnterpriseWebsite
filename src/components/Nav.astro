---
import bbSymbol from "@assets/logos/bbSymbol.svg";
import { Image } from "astro:assets";
import House from "phosphor-astro/HouseFill.astro";
import Coins from "phosphor-astro/CoinsFill.astro";
import Users from "phosphor-astro/UsersFill.astro";
import Dots from "phosphor-astro/DotsThreeCircleFill.astro";
---

<div
  class="flex justify-between items-center px-4 lg:pl-12 lg:pr-6 py-1 flex-wrap gap-2 w-full mx-auto border-b border-stone-200"
>
  <div class="flex items-center">
    <a href="/">
      <div class="w-5 h-5">
        <Image
          src={bbSymbol}
          alt="Budibase symbol"
          class="hover:cursor-pointer"
        />
      </div>
    </a>
  </div>
  <div class="flex flex-wrap gap-2">
    <a target="_self" href="/pricing" data-astro-prefetch>
      <div
        class="hidden sm:block text-sm py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
      >
        Ecosystem
      </div>
    </a>
    <a target="_self" href="/pricing" data-astro-prefetch>
      <div
        class="hidden sm:block text-sm py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
      >
        Pricing
      </div>
    </a>
    <a target="_self" href="/company" data-astro-prefetch>
      <div
        class="hidden sm:block text-sm py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
      >
        Resources
      </div>
    </a>
    <a target="_self" href="/blog" data-astro-prefetch>
      <div
        class="text-sm py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
      >
        Talk to sales
      </div>
    </a>
    <a target="_self" href="/blog" data-astro-prefetch>
      <div
        class="text-sm py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
      >
        Sign in
      </div>
    </a>

    <a href="/talk-to-our-team" class="pl-1 md:pl-2">
      <button class="text-sm">Try for free</button>
    </a>
  </div>
</div>

<!--footer-->
<div
  class="fixed sm:hidden bottom-0 left-0 right-0 bg-ivory-medium w-full flex flex-row gap-6 items-center justify-between py-2 px-5 z-50 border-t border-stone-200"
>
  <a href="/">
    <div
      class="sm:hidden text-sm flex flex-col items-center rounded-full transition-all font-medium text-slate-dark"
    >
      <House class="fill-slate w-5" />
      Home
    </div>
  </a>
  <div
    class="sm:hidden text-sm flex flex-col items-center rounded-full transition-all font-medium text-slate-dark"
  >
    <Users class="fill-slate w-5" />
    Community
  </div>
  <a href="/pricing">
    <div
      class="sm:hidden text-sm flex flex-col items-center rounded-full transition-all font-medium text-slate-dark"
    >
      <Coins class="fill-slate w-5" />
      Pricing
    </div>
  </a>
  <div
    class="sm:hidden text-sm flex flex-col items-center rounded-full transition-all font-medium text-slate-dark"
  >
    <Dots class="fill-slate w-5" />
    Resources
  </div>
</div>
<style>
  button {
    background-color: var(--slate-dark);
    color: white;
    font-weight: 500;
    border-radius: 20px;
    font-size: 14px;
    line-height: 14px;
    padding: 6px 8px;
    transition: 150ms background-color ease-out;
    display: flex;
  }

  button:hover {
    background-color: var(--slate-light);
  }
</style>
