---
// Reusable Button component
// Props:
// - label: string (required)
// - url?: string (if provided, renders an anchor)
// - variant?: 'primary' | 'secondary' | 'cta' (defaults to 'primary')
// - type?: 'button' | 'submit' | 'reset' (button only)
// - class?: string (additional classes)
// - size?: 'small' | 'medium' | 'large' (defaults to 'medium')

type Variant = "primary" | "secondary" | "cta";

interface Props {
  label: string;
  url?: string;
  variant?: Variant;
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
  size?: "small" | "medium" | "large";
}

const {
  label,
  url,
  variant = "primary",
  type = "button",
  class: className = "",
  ariaLabel,
  size = "medium",
} = Astro.props as Props;

const sizeClass = size !== "medium" ? size : "";
const classes = ["btn", variant, sizeClass, className]
  .filter(Boolean)
  .join(" ");
---

{
  url ? (
    <a href={url} class={classes} aria-label={ariaLabel} role="button">
      <span class="label">{label}</span>
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel}>
      <span class="label">{label}</span>
    </button>
  )
}

<style>
  /* Base button look shared for <a> and <button> */
  .btn {
    transition: 150ms;
    text-transform: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-decoration: none;
    border: none;
    cursor: default;
    font-family: var(--font-sans);
  }

  .btn:active {
    transform: scale(0.98);
  }

  /* Variants mirror src/styles/global.css button styles */
  .btn.cta {
    background-color: var(--color-sky-700);
    color: white;
    font-weight: 400;
    font-size: 16px;
    border-radius: 50px;
    padding: 3px 12px;
    transition: 150ms background-color ease-out;
  }
  .btn.cta:hover {
    background-color: var(--color-sky-900);
  }

  .btn.primary {
    background-color: var(--color-theme-fg);
    color: var(--color-theme-bg);
    font-weight: 400;
    font-size: 16px;
    border-radius: 50px;
    padding: 6px 12px;
    transition: 150ms background-color ease-out;
  }
  .btn.primary:hover {
    background-color: var(--gray-600);
  }

  .btn.secondary {
    background-color: var(--gray-50);
    color: var(--color-theme-fg);
    border: 1px solid var(--gray-300);
    font-weight: 400;
    font-size: 16px;
    border-radius: 50px;
    padding: 6px 12px;
    transition: 150ms background-color ease-out;
  }
  .btn.secondary:hover {
    background-color: var(--gray-100);
  }

  /* Sizes */
  /* Mirrors button.small in global.css */
  .btn.small {
    padding: 4.5px 10px;
    border-radius: 50px;
    font-size: 14px;
  }
  /* Large complements base scale (6px 12px @16px) */
  .btn.large {
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 18px;
  }
</style>
