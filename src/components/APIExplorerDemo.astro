---
import { Image } from "astro:assets";
import CaretDown from "phosphor-astro/CaretDown.astro";
import Cube from "phosphor-astro/Cube.astro";
import PaperPlaneTilt from "phosphor-astro/PaperPlaneTilt.astro";

import Icon from "@components/Icon.astro";
import StripeLogo from "@assets/logos/stripe.svg";
import NotionLogo from "@assets/logos/notion.svg";
import JiraLogo from "@assets/logos/Jira.svg";
import ServiceNowLogo from "@assets/logos/servicenow.svg";
import SalesforceLogo from "@assets/logos/Salesforce.svg";
import SharepointLogo from "@assets/logos/microsoft-sharepoint.svg";
import ZendeskLogo from "@assets/logos/zendesk.svg";
import SageLogo from "@assets/logos/sage.svg";

const id = `api-explorer-demo-${Math.random().toString(36).slice(2, 8)}`;

const responsePayload = `{
  "id": "cus_NffrFeUfNV2Hib",
  "object": "customer",
  "address": null,
  "balance": 0,
  "created": 1680893993,
  "currency": null,
  "default_source": null,
  "delinquent": false,
  "description": null,
  "email": "jennyrosen@example.com",
  "invoice_prefix": "0759376C",
  "invoice_settings": {
    "custom_fields": null,
    "default_payment_method": null,
    "footer": null,
    "rendering_options": null
  },
  "livemode": false,
  "metadata": {},
  "name": "Jenny Rosen",
  "next_invoice_sequence": 1
}`;
---

<div id={id} class="api-explorer-demo w-full">
  <div class="api-explorer-demo-backdrop px-24 py-12 w-[120%] -ml-[10%]">
    <div
      class="api-explorer-demo-shell overflow-hidden rounded-[8px] border-[0.5px] border-[var(--api-demo-border)]"
    >
      <div
        class="group relative flex h-7 items-center justify-between border-b-[0.5px] border-[var(--border-color)] bg-[var(--bg-2)] px-2"
      >
        <div class="flex items-center gap-1.5">
          <span
            class="api-explorer-demo-window-dot inline-block h-2.5 w-2.5 rounded-full"
          ></span>
          <span
            class="api-explorer-demo-window-dot inline-block h-2.5 w-2.5 rounded-full"
          ></span>
          <span
            class="api-explorer-demo-window-dot inline-block h-2.5 w-2.5 rounded-full"
          ></span>
        </div>
        <div class="absolute left-1/2 top-1/2 w-[540px] -translate-x-1/2 -translate-y-1/2">
          <input
            type="text"
            placeholder="budibase/api-explorer"
            aria-label="Search"
            class="h-5 w-full rounded-[4px] border-0 bg-[var(--bg-1)] px-2.5 text-[12px] text-[var(--text-primary)] outline-none placeholder:text-[var(--text-secondary)]"
          />
        </div>
        <div class="-mr-1 flex items-center">
          <button
            type="button"
            class="cursor-pointer rounded px-2 py-1 text-[12px] text-[var(--text-secondary)] transition-opacity duration-200 hover:bg-[rgb(var(--text)/0.06)]"
          >
            Get Budibase
          </button>
        </div>
      </div>

      <div class="flex min-h-0">
        <div class="min-w-0 flex-1">
          <div class="api-explorer-demo-main flex flex-col xl:flex-row">
            <div
              class="api-explorer-demo-center min-w-0 flex-1 border-t-[0.5px] border-[var(--api-demo-border)]"
            >
              <div class="api-explorer-demo-controls px-5 py-3">
                <div
                  class="api-explorer-demo-control-row flex items-center gap-5"
                >
                  <div class="api-explorer-demo-select-wrap">
                    <button
                      class="api-explorer-demo-connection"
                      type="button"
                      aria-expanded="false"
                      data-api-demo-select
                    >
                      <span class="flex min-w-0 items-center gap-2.5">
                        <Image
                          src={StripeLogo}
                          alt="Stripe"
                          class="h-5 w-5 rounded-[8px]"
                        />
                        <span class="truncate" data-api-demo-select-value
                          >Stripe Production</span
                        >
                      </span>

                      <span class="flex items-center gap-2">
                        <span class="api-explorer-demo-auth-chip">
                          <Icon
                            name="CheckCircle"
                            weight="fill"
                            class="h-3.5 w-3.5 text-[var(--accent-green)]"
                          />
                          <span>Auth connected</span>
                        </span>
                        <CaretDown
                          class="h-3.5 w-3.5 text-[var(--text-secondary)]"
                        />
                      </span>
                    </button>

                    <div
                      class="api-explorer-demo-select-menu"
                      data-api-demo-menu
                    >
                      <div class="api-explorer-demo-select-search-wrap">
                        <input
                          type="text"
                          placeholder="Search connectors"
                          aria-label="Search connectors"
                          class="api-explorer-demo-select-search"
                        />
                      </div>

                      <div class="api-explorer-demo-select-label">Saved</div>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Stripe Production"
                      >
                        <Image
                          src={StripeLogo}
                          alt="Stripe Production"
                          class="h-4 w-4"
                        />
                        Stripe Production
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Stripe Development"
                      >
                        <Image
                          src={StripeLogo}
                          alt="Stripe Development"
                          class="h-4 w-4"
                        />
                        Stripe Development
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Notion"
                      >
                        <Image src={NotionLogo} alt="Notion" class="h-4 w-4" />
                        Notion
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Jira"
                      >
                        <Image src={JiraLogo} alt="Jira" class="h-4 w-4" />
                        Jira
                      </button>
                      <div class="api-explorer-demo-select-label">
                        Available connectors
                      </div>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Servicenow"
                      >
                        <Image
                          src={ServiceNowLogo}
                          alt="Servicenow"
                          class="h-4 w-4"
                        />
                        Servicenow
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Salesforce"
                      >
                        <Image
                          src={SalesforceLogo}
                          alt="Salesforce"
                          class="h-4 w-4"
                        />
                        Salesforce
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Microsoft Sharepoint"
                      >
                        <Image
                          src={SharepointLogo}
                          alt="Microsoft Sharepoint"
                          class="h-4 w-4"
                        />
                        Microsoft Sharepoint
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Zendesk"
                      >
                        <Image
                          src={ZendeskLogo}
                          alt="Zendesk"
                          class="h-4 w-4"
                        />
                        Zendesk
                      </button>
                      <button
                        class="api-explorer-demo-select-option"
                        type="button"
                        data-api-demo-option="Sage"
                      >
                        <Image src={SageLogo} alt="Sage" class="h-4 w-4" />
                        Sage
                      </button>
                      <a
                        class="api-explorer-demo-select-option"
                        href="/platform/connections/"
                      >
                        <Cube class="api-explorer-demo-connector-icon h-4 w-4" />
                        View all Connectors
                      </a>
                    </div>
                  </div>

                  <div class="api-explorer-demo-operation-wrap">
                    <button
                      class="api-explorer-demo-operation justify-start"
                      type="button"
                      aria-expanded="false"
                      data-api-demo-operation-select
                    >
                      <span
                        class="api-explorer-demo-method api-explorer-demo-method-post"
                        data-api-demo-operation-method
                        >POST</span
                      >
                      <span data-api-demo-operation-label
                        >/v1/customers</span
                      >
                      <CaretDown
                        class="ml-auto h-3.5 w-3.5 text-[var(--text-secondary)]"
                      />
                    </button>

                    <div
                      class="api-explorer-demo-operation-menu"
                      data-api-demo-operation-menu
                    >
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="POST"
                        data-api-demo-operation-endpoint-value="/v1/customers"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-post"
                          >POST</span
                        >
                        <span>/v1/customers</span>
                      </button>
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="POST"
                        data-api-demo-operation-endpoint-value="/v1/customers/:id"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-post"
                          >POST</span
                        >
                        <span>/v1/customers/:id</span>
                      </button>
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="GET"
                        data-api-demo-operation-endpoint-value="/v1/customers/:id"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-get"
                          >GET</span
                        >
                        <span>/v1/customers/:id</span>
                      </button>
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="GET"
                        data-api-demo-operation-endpoint-value="/v1/customers"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-get"
                          >GET</span
                        >
                        <span>/v1/customers</span>
                      </button>
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="DEL"
                        data-api-demo-operation-endpoint-value="/v1/customers/:id"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-del"
                          >DEL</span
                        >
                        <span>/v1/customers/:id</span>
                      </button>
                      <button
                        class="api-explorer-demo-operation-option"
                        type="button"
                        data-api-demo-operation-option
                        data-api-demo-operation-method-value="GET"
                        data-api-demo-operation-endpoint-value="/v1/customers/search"
                      >
                        <span
                          class="api-explorer-demo-method api-explorer-demo-method-get"
                          >GET</span
                        >
                        <span>/v1/customers/search</span>
                      </button>
                    </div>
                  </div>
                </div>

                <div
                  class="api-explorer-demo-control-row mt-3 flex items-center gap-5"
                >
                  <div class="api-explorer-demo-path" data-api-demo-endpoint></div>

                  <button
                    class="api-explorer-demo-send"
                    type="button"
                    data-api-demo-send
                  >
                    <PaperPlaneTilt class="h-3.5 w-3.5" weight="fill" />
                    Send
                  </button>
                </div>
              </div>

              <div
                class="api-explorer-demo-body border-t-[0.5px] border-[var(--api-demo-border)]"
              >
                <div class="api-explorer-demo-tabs px-5 pt-4">
                  <button class="is-active" type="button">Params</button>
                  <button type="button">Bindings</button>
                  <button type="button">Pagination</button>
                  <button type="button">Transformer</button>
                  <button type="button">Information</button>
                </div>

                <div class="px-5 py-3">
                  <div class="api-explorer-demo-section-title">Query</div>
                  <div class="api-explorer-demo-grid mt-2">
                    <div class="api-explorer-demo-row">
                      <span>id*</span>
                      <span class="api-explorer-demo-type">Str</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>opt_pretty*</span>
                      <span class="api-explorer-demo-type">Bool</span>
                    </div>
                  </div>

                  <div class="api-explorer-demo-section-title mt-5">Body</div>
                  <div class="api-explorer-demo-grid mt-2">
                    <div class="api-explorer-demo-row">
                      <span>color</span>
                      <span class="api-explorer-demo-type">Str</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>notes</span>
                      <span class="api-explorer-demo-type">Str</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>workspace</span>
                      <span class="api-explorer-demo-type">Obj</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>default_view</span>
                      <span class="api-explorer-demo-type">Str</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>custom_fields</span>
                      <span class="api-explorer-demo-type">Obj</span>
                    </div>
                    <div class="api-explorer-demo-row">
                      <span>is_template</span>
                      <span class="api-explorer-demo-type">Bool</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <aside
              class="api-explorer-demo-right w-full border-t-[0.5px] border-[var(--api-demo-border)] xl:w-[320px] xl:border-l-[0.5px] xl:border-t-0"
            >
              <div class="api-explorer-demo-response-tabs">
                <button type="button">Schema</button>
                <button class="is-active" type="button">Response</button>
              </div>
              <pre class="api-explorer-demo-response" data-api-demo-response>
              </pre>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id, responsePayload }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const select = root.querySelector("[data-api-demo-select]");
    const selectValue = root.querySelector("[data-api-demo-select-value]");
    const selectMenu = root.querySelector("[data-api-demo-menu]");
    const selectWrap = root.querySelector(".api-explorer-demo-select-wrap");
    const options = root.querySelectorAll("[data-api-demo-option]");
    const operationSelect = root.querySelector("[data-api-demo-operation-select]");
    const operationMethod = root.querySelector("[data-api-demo-operation-method]");
    const operationLabel = root.querySelector("[data-api-demo-operation-label]");
    const operationMenu = root.querySelector("[data-api-demo-operation-menu]");
    const operationWrap = root.querySelector(".api-explorer-demo-operation-wrap");
    const endpointDisplay = root.querySelector("[data-api-demo-endpoint]");
    const operationOptions = root.querySelectorAll(
      "[data-api-demo-operation-option]",
    );
    const sendButton = root.querySelector("[data-api-demo-send]");
    const response = root.querySelector("[data-api-demo-response]");

    if (!select || !selectValue || !selectMenu || !response) return;

    let animationId = 0;
    const thinkingDuration = 2200;
    const typingDelay = 8;

    function closeMenu() {
      selectMenu.classList.remove("is-open");
      select.setAttribute("aria-expanded", "false");
    }

    function openMenu() {
      selectMenu.classList.add("is-open");
      select.setAttribute("aria-expanded", "true");
    }

    function closeOperationMenu() {
      if (!operationSelect || !operationMenu) return;
      operationMenu.classList.remove("is-open");
      operationSelect.setAttribute("aria-expanded", "false");
    }

    function openOperationMenu() {
      if (!operationSelect || !operationMenu) return;
      operationMenu.classList.add("is-open");
      operationSelect.setAttribute("aria-expanded", "true");
    }

    function methodVariant(method) {
      const normalized = method.toLowerCase();
      if (normalized === "delete" || normalized === "del") return "del";
      if (normalized === "post") return "post";
      return "get";
    }

    function renderEndpoint(endpoint) {
      if (!endpointDisplay) return;
      const segments = endpoint.split("/").filter(Boolean);

      if (segments.length === 0) {
        endpointDisplay.textContent = endpoint;
        return;
      }

      const html = [];
      segments.forEach((segment, index) => {
        html.push('<span class="text-[var(--api-demo-muted)]">/</span>');
        if (segment === ":id") {
          html.push('<span class="api-explorer-demo-id-token">:id</span>');
        } else {
          html.push(escapeHtml(segment));
        }
        if (index === segments.length - 1) return;
      });

      endpointDisplay.innerHTML = html.join("");
    }

    function setOperation(method, endpoint) {
      if (!operationMethod || !operationLabel) return;

      operationMethod.textContent = method;
      operationLabel.textContent = endpoint;
      operationMethod.classList.remove(
        "api-explorer-demo-method-get",
        "api-explorer-demo-method-post",
        "api-explorer-demo-method-del",
      );
      operationMethod.classList.add(
        `api-explorer-demo-method-${methodVariant(method)}`,
      );
      renderEndpoint(endpoint);
    }

    function sleep(duration) {
      return new Promise((resolve) => {
        window.setTimeout(resolve, duration);
      });
    }

    function createThinking() {
      const wrapper = document.createElement("div");
      wrapper.className = "api-explorer-demo-thinking";
      wrapper.textContent = "Thinking";

      const dots = document.createElement("span");
      dots.className = "api-explorer-demo-thinking-dots";

      for (let i = 0; i < 3; i += 1) {
        const dot = document.createElement("span");
        dot.className = "api-explorer-demo-thinking-dot";
        dots.append(dot);
      }

      wrapper.append(" ");
      wrapper.append(dots);
      return wrapper;
    }

    function escapeHtml(value) {
      return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    function highlightJson(jsonText) {
      const escaped = escapeHtml(jsonText);
      return escaped.replace(
        /("(?:\\u[\da-fA-F]{4}|\\[^u]|[^\\"])*")(\s*:)?|\btrue\b|\bfalse\b|\bnull\b|-?\d+(?:\.\d+)?(?:[eE][+\-]?\d+)?/g,
        (match, stringToken, colon) => {
          if (stringToken) {
            if (colon) {
              return `<span class="api-explorer-demo-json-key">${stringToken}</span>${colon}`;
            }
            return `<span class="api-explorer-demo-json-string">${stringToken}</span>`;
          }

          if (match === "true" || match === "false") {
            return `<span class="api-explorer-demo-json-boolean">${match}</span>`;
          }

          if (match === "null") {
            return `<span class="api-explorer-demo-json-null">${match}</span>`;
          }

          return `<span class="api-explorer-demo-json-number">${match}</span>`;
        },
      );
    }

    function renderResponse(content) {
      response.innerHTML = highlightJson(content);
    }

    async function streamResponse() {
      animationId += 1;
      const currentId = animationId;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReducedMotion) {
        renderResponse(responsePayload);
        return;
      }

      response.textContent = "";
      response.append(createThinking());
      await sleep(thinkingDuration);

      if (currentId !== animationId) return;

      response.textContent = "";
      for (let i = 0; i <= responsePayload.length; i += 1) {
        if (currentId !== animationId) return;
        renderResponse(responsePayload.slice(0, i));
        response.scrollTop = response.scrollHeight;
        await sleep(typingDelay);
      }
    }

    select.addEventListener("click", (event) => {
      event.stopPropagation();
      if (selectMenu.classList.contains("is-open")) {
        closeMenu();
      } else {
        closeOperationMenu();
        openMenu();
      }
    });

    options.forEach((option) => {
      option.addEventListener("click", () => {
        const value = option.getAttribute("data-api-demo-option");
        if (value) {
          selectValue.textContent = value;
        }
        closeMenu();
      });
    });

    if (operationSelect && operationMenu) {
      operationSelect.addEventListener("click", (event) => {
        event.stopPropagation();
        if (operationMenu.classList.contains("is-open")) {
          closeOperationMenu();
        } else {
          closeMenu();
          openOperationMenu();
        }
      });
    }

    operationOptions.forEach((option) => {
      option.addEventListener("click", () => {
        const method = option.getAttribute("data-api-demo-operation-method-value");
        const endpoint = option.getAttribute(
          "data-api-demo-operation-endpoint-value",
        );
        if (method && endpoint) {
          setOperation(method, endpoint);
        }
        closeOperationMenu();
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;

      if (!root.contains(target)) {
        closeOperationMenu();
        closeMenu();
        return;
      }

      if (selectWrap && !selectWrap.contains(target)) {
        closeMenu();
      }

      if (operationWrap && !operationWrap.contains(target)) {
        closeOperationMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeOperationMenu();
        closeMenu();
      }
    });

    if (sendButton) {
      sendButton.addEventListener("click", () => {
        streamResponse();
      });
    }

    if (operationMethod && operationLabel) {
      setOperation(
        operationMethod.textContent?.trim() ?? "POST",
        operationLabel.textContent?.trim() ?? "/v1/customers",
      );
    }

    streamResponse();
  })();
</script>
