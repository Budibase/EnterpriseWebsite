---
import Button from "@components/Button.astro";

interface Props {
  prompt: string;
  title?: string;
  agentTitle?: string;
  toolsUsed?: string[];
}

const {
  prompt,
  title = "Prompt",
  agentTitle,
  toolsUsed = [],
} = Astro.props as Props;
---

<section
  class="agent-prompt-panel"
  data-agent-prompt-panel
  data-agent-title={agentTitle ?? ""}
  data-tools-used={toolsUsed.join(" | ")}
>
  <div class="agent-prompt-panel-header">
    <p class="agent-prompt-panel-title">{title}</p>
    <Button
      label="Copy"
      variant="secondary"
      size="small"
      class="agent-prompt-panel-copy-button"
      ariaLabel="Copy prompt"
    />
  </div>
  <pre class="agent-prompt-panel-content" data-agent-prompt-content>{prompt}</pre>
  <div class="agent-prompt-panel-footer" aria-hidden="true"></div>
  <div class="agent-prompt-panel-view-action" data-agent-prompt-open-modal>
    <Button
      label="View prompt"
      variant="primary"
      size="small"
      class="agent-prompt-panel-view-primary"
    />
  </div>
</section>

<style>
  .agent-prompt-panel {
    position: relative;
    height: 100%;
    border: 0.5px solid var(--border-color);
    border-radius: 0.8rem;
    background: var(--bg-1);
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 18rem;
  }

  .agent-prompt-panel-header {
    border-bottom: 0.5px solid var(--border-color);
    padding: 0.55rem 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .agent-prompt-panel-title {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .agent-prompt-panel-footer {
    border-top: 0.5px solid var(--border-color);
    min-height: 2.6rem;
    margin-top: 0.1rem;
  }

  .agent-prompt-panel-view-action {
    position: absolute;
    left: 50%;
    bottom: 0.45rem;
    transform: translateX(-50%);
    z-index: 2;
    display: inline-flex;
  }

  .agent-prompt-panel-content {
    margin: 0;
    padding: 0.9rem 0.85rem 1rem;
    color: rgb(var(--text-article));
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.45;
    white-space: pre-wrap;
    overflow: auto;
    background: transparent !important;
    border: 0 !important;
  }
</style>

<script is:inline>
  (() => {
    const initPromptPanels = () => {
      const panels = Array.from(
        document.querySelectorAll("[data-agent-prompt-panel]"),
      );

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        if (panel.dataset.agentPromptReady === "true") return;
        panel.dataset.agentPromptReady = "true";

        const copyButton = panel.querySelector(".agent-prompt-panel-copy-button");
        const openButton = panel.querySelector(
          "[data-agent-prompt-open-modal]",
        );
        const content = panel.querySelector("[data-agent-prompt-content]");
        if (!(copyButton instanceof HTMLButtonElement)) return;
        if (!(openButton instanceof HTMLElement)) return;
        if (!(content instanceof HTMLElement)) return;

        copyButton.addEventListener("click", async () => {
          const raw = content.textContent ?? "";
          const prompt = raw.trim();
          if (!prompt) return;

          try {
            await navigator.clipboard.writeText(prompt);
            const previousText = copyButton.textContent;
            copyButton.textContent = "Copied";
            window.setTimeout(() => {
              copyButton.textContent = previousText;
            }, 1200);
          } catch {
            copyButton.textContent = "Failed";
            window.setTimeout(() => {
              copyButton.textContent = "Copy";
            }, 1200);
          }
        });

        openButton.addEventListener("click", () => {
          const prompt = (content.textContent ?? "").trim();
          if (!prompt) return;
          window.dispatchEvent(
            new CustomEvent("agent:open-prompt-modal", {
              detail: { promptText: prompt },
            }),
          );
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initPromptPanels, {
        once: true,
      });
    } else {
      initPromptPanels();
    }

    document.addEventListener("astro:after-swap", initPromptPanels);
  })();
</script>
