---
import Link from "@components/Link.astro";
import Check from "phosphor-astro/CheckCircle.astro";
import Monitor from "phosphor-astro/Monitor.astro";
import Sun from "phosphor-astro/Sun.astro";
import Moon from "phosphor-astro/Moon.astro";

interface FooterLink {
  label: string;
  url: string;
  target?: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

const footerColumns: FooterColumn[] = [
  {
    title: "Product",
    links: [
      { label: "Chat", url: "/chat" },
      { label: "Agents", url: "/agents" },
      { label: "Automations", url: "/automations" },
      { label: "Apps", url: "/apps" },
      { label: "Enterprise", url: "/enterprise" },
      { label: "Pricing", url: "/pricing" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Community", url: "/community" },
      { label: "Integrations", url: "/blog" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", url: "/blog" },
      { label: "Changelog", url: "/changelog" },
      { label: "Docs", url: "/docs" },
      { label: "Community", url: "/community" },
      { label: "Blog", url: "/blog" },
      { label: "Status", url: "/status" },
      { label: "Company", url: "/company" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Terms of Service", url: "/terms" },
      { label: "Privacy Policy", url: "/privacy" },
      { label: "Data Use", url: "/data-use" },
      { label: "Security", url: "/security" },
    ],
  },
  {
    title: "Connect",
    links: [
      { label: "X", url: "https://twitter.com/budibase", target: "_blank" },
      { label: "LinkedIn", url: "https://linkedin.com/company/budibase", target: "_blank" },
      { label: "YouTube", url: "https://youtube.com/@budibase", target: "_blank" },
    ],
  },
];
---

<footer class="footer  bg-secondary">
  <div class="footer-container max-w-7xl container mx-auto">
    <!-- Upper section: Navigation columns -->
    <div class="footer-nav">
      {footerColumns.map((column) => (
        <div class="footer-column">
          <p>{column.title}</p>
          <ul class="text-stone-500! gap-0.5! flex flex-col">
            {column.links.map((link) => (
              <li>
                <Link
                  label={link.label}
                  url={link.url}
                  target={link.target}
                  variant="secondary"
                  size="small"
                  class="footer-link"
                />
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Lower section: Copyright and controls -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        <span>© 2025 Budibase, Inc.</span>
        <span class="footer-certification">
          <Check class="footer-check-icon" />
          <span>SOC 2 Certified</span>
        </span>
        <span class="footer-certification">
          <Check class="footer-check-icon" />
          <span>ISO27001 Certified</span>
        </span>
        <span class="footer-certification">
          <Check class="footer-check-icon" />
          <span>GDPR Compliant</span>
        </span>
        <span class="footer-certification">
          <Check class="footer-check-icon" />
          <span>Made in Europe</span>
        </span>
      </div>
      <div class="footer-controls">
        <!-- Theme switcher -->
        <div class="theme-switcher" role="group" aria-label="Theme selection">
          <button
            class="theme-button"
            aria-label="System theme"
            data-theme="system"
          >
            <Monitor class="theme-icon" />
          </button>
          <button
            class="theme-button theme-button-active"
            aria-label="Light theme"
            data-theme="light"
          >
            <Sun class="theme-icon" />
          </button>
          <button
            class="theme-button"
            aria-label="Dark theme"
            data-theme="dark"
          >
            <Moon class="theme-icon" />
          </button>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 0 1.5rem;
    margin-top: auto;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--gray-200);
  }

  .footer-copyright {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .footer-certification {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-check-icon {
    width: 16px;
    height: 16px;
    color: var(--text-secondary);
  }

  .footer-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .theme-switcher {
    display: flex;
    background-color: var(--gray-100);
    border-radius: 6px;
    padding: 2px;
    gap: 2px;
  }

  .theme-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 150ms ease-out;
    color: var(--text-secondary);
  }

  .theme-button:hover {
    background-color: var(--gray-200);
  }

  .theme-button-active {
    background-color: var(--color-theme-bg);
    color: var(--color-theme-fg);
  }

  .theme-icon {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 768px) {
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-controls {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

