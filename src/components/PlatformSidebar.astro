---
interface NavItem {
	text: string;
	link: string;
	sectionId: string;
	icon?: any;
}

interface Props {
	title: string;
	description: string;
	navItems: NavItem[];
}

const { title, description, navItems } = Astro.props;
---

<aside class="platform-sidebar">
	<h1 class="mb-4">{title}</h1>
	<p class="text-stone-500! dark:text-stone-400! mb-4!">{description}</p>
	<nav>
		<ul>
			{navItems.map((item) => (
				<li>
					<a href={item.link} class="nav-link flex flex-row gap-2 items-center h-8 px-2 rounded text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 [&.active]:text-stone-900 [&.active]:dark:text-stone-100 [&.active]:font-medium" data-section={item.sectionId}>
						{item.icon && <item.icon class="w-4 h-4" />}
						<span>{item.text}</span>
					</a>
				</li>
			))}
		</ul>
	</nav>
</aside>

<style>
	.platform-sidebar {
		position: sticky;
		top: 2rem;
		width: 280px;
	}

	.nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}


	@media (max-width: 768px) {
		.platform-sidebar {
			position: static;
		}

		.nav-list {
			flex-direction: row;
			overflow-x: auto;
		}

		.nav-link {
			white-space: nowrap;
		}
	}
</style>

