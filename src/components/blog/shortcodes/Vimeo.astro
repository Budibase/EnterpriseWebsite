---
interface Props {
  id: string;
  title?: string;
}

const { id, title = "Vimeo video" } = Astro.props;
const src =
  `https://player.vimeo.com/video/${id}?autoplay=1&muted=1&loop=1&autopause=0&controls=0`;
---

<div class="not-prose my-8">
  <div class="aspect-video overflow-hidden rounded-sm border">
    <iframe
      src={src}
      title={title}
      class="h-full w-full"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</div>

<script src="https://player.vimeo.com/api/player.js"></script>
