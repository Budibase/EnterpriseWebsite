---
// Logo imports
import BambooLogo from "@assets/logos/Bamboo.svg?url";
import ConfluenceLogo from "@assets/logos/confluence.svg?url";
import DatadogLogo from "@assets/logos/datadog.svg?url";
import DockerLogo from "@assets/logos/Docker.svg?url";
import ElasticsearchLogo from "@assets/logos/elasticsearch.svg?url";
import GitLabLogo from "@assets/logos/gitlab.svg?url";
import GithubLogoSvg from "@assets/logos/github.svg?url";
import GoogleLogo from "@assets/logos/Google.svg?url";
import HubSpotLogo from "@assets/logos/hubspot.svg?url";
import JiraLogo from "@assets/logos/Jira.svg?url";
import KubernetesLogo from "@assets/logos/kubernetes.svg?url";
import MicrosoftSharePointLogo from "@assets/logos/microsoft-sharepoint.svg?url";
import MistralLogo from "@assets/logos/Mistral.svg?url";
import MongoDBLogo from "@assets/logos/mongodb.svg?url";
import MySQLLogo from "@assets/logos/MYSQL.svg?url";
import OktaLogo from "@assets/logos/okta.jpeg?url";
import OpenAILogo from "@assets/logos/OpenAI.svg?url";
import OracleLogo from "@assets/logos/Oracle.svg?url";
import PagerDutyLogo from "@assets/logos/pagerduty.jpeg?url";
import PostgresLogo from "@assets/logos/Postgres.svg?url";
import SalesforceLogo from "@assets/logos/Salesforce.svg?url";
import ServiceNowLogo from "@assets/logos/servicenow.svg?url";
import SlackLogo from "@assets/logos/Slack.svg?url";
import SnowflakeLogo from "@assets/logos/Snowflake.svg?url";
import SplunkLogo from "@assets/logos/splunk.svg?url";
import TeamsLogo from "@assets/logos/microsoft-teams.svg?url";
import WorkdayLogo from "@assets/logos/Workday.jpeg?url";
import ZendeskLogo from "@assets/logos/zendesk.svg?url";

const logos = [
  { src: ServiceNowLogo, alt: "ServiceNow" },
  { src: SalesforceLogo, alt: "Salesforce" },
  { src: BambooLogo, alt: "Bamboo" },
  { src: WorkdayLogo, alt: "Workday" },
  { src: HubSpotLogo, alt: "HubSpot" },
  { src: MicrosoftSharePointLogo, alt: "Microsoft SharePoint" },
  { src: GoogleLogo, alt: "Google" },
  { src: ConfluenceLogo, alt: "Confluence" },
  { src: JiraLogo, alt: "Jira" },
  { src: ZendeskLogo, alt: "Zendesk" },
  { src: OktaLogo, alt: "Okta" },
  { src: GithubLogoSvg, alt: "GitHub" },
  { src: GitLabLogo, alt: "GitLab" },
  { src: PostgresLogo, alt: "PostgreSQL" },
  { src: MySQLLogo, alt: "MySQL" },
  { src: MongoDBLogo, alt: "MongoDB" },
  { src: ElasticsearchLogo, alt: "Elasticsearch" },
  { src: OracleLogo, alt: "Oracle" },
  { src: SnowflakeLogo, alt: "Snowflake" },
  { src: DatadogLogo, alt: "Datadog" },
  { src: SplunkLogo, alt: "Splunk" },
  { src: PagerDutyLogo, alt: "PagerDuty" },
  { src: DockerLogo, alt: "Docker" },
  { src: KubernetesLogo, alt: "Kubernetes" },
  { src: TeamsLogo, alt: "Microsoft Teams" },
  { src: SlackLogo, alt: "Slack" },
  { src: OpenAILogo, alt: "OpenAI" },
  { src: MistralLogo, alt: "Mistral" },
];

const mobileVisibleLogos = logos;
const desktopVisibleLogos = logos;
---

<div
  class="integration-banner-shell mx-auto w-full max-w-full overflow-hidden rounded-lg"
>
  <div
    class="integration-banner-grid grid grid-cols-[repeat(5,minmax(0,48px))] auto-rows-[48px] justify-start gap-2 py-4 sm:hidden"
  >
    {
      mobileVisibleLogos.map((logo) => {
        return (
          <div
            class="integration-banner-logo shadow-2 flex h-[48px] w-[48px] shrink-0 items-center justify-center overflow-hidden rounded-sm bg-3 p-2.5"
            style="opacity: 1; transition: opacity 300ms;"
          >
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-full w-full object-contain"
              width={72}
              height={72}
            />
          </div>
        );
      })
    }
  </div>

  <div
    class="integration-banner-grid hidden grid-cols-[repeat(7,minmax(0,44px))] auto-rows-[44px] justify-start gap-2 py-6 sm:grid md:grid-cols-[repeat(14,50px)] md:grid-rows-[repeat(2,50px)] md:py-8 lg:grid-cols-[repeat(14,60px)] lg:grid-rows-[repeat(2,60px)]"
  >
    {
      desktopVisibleLogos.map((logo) => {
        return (
          <div
            class="integration-banner-logo shadow-2 flex h-[44px] w-[44px] shrink-0 items-center justify-center overflow-hidden rounded-sm bg-3 p-2 md:h-[50px] md:w-[50px] md:p-4 lg:h-[60px] lg:w-[60px]"
            style="opacity: 1; transition: opacity 300ms;"
          >
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-full w-full object-contain"
              width={72}
              height={72}
            />
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .integration-banner-shell {
    position: relative;
    isolation: isolate;
  }

  .integration-banner-grid {
    width: 100%;
    max-width: 100%;
  }
</style>
