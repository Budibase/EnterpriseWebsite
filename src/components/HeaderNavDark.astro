---
import bbSymbol from "../assets/logos/bbSymbolWhite.svg";
import { Image } from "astro:assets";
---

<div
  class="flex justify-between items-center p-4 flex-wrap gap-2 w-full mx-auto"
>
  <div class="flex items-center">
    <a href="/">
      <div class="w-8 h-8">
        <Image
          src={bbSymbol}
          alt="Budibase symbol"
          class="hover:cursor-pointer"
        />
      </div>
    </a>
  </div>
  <div
    class="flex items-center flex-wrap gap-0 md:gap-2 bg-ivory-light p-1 rounded-xl"
  >
    <div class="flex rounded-full transition-all">
      <a target="_self" href="/pricing" data-astro-prefetch>
        <div
          class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
        >
          Community
        </div>
      </a>

      <a target="_self" href="/pricing" data-astro-prefetch>
        <div
          class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
        >
          Pricing
        </div>
      </a>
      <a target="_self" href="/blog" data-astro-prefetch>
        <div
          class="py-1 pl-1 md:pl-2 pr-1 md:pr-2 rounded-full transition-all font-medium bg-transparent text-slate-dark"
        >
          Resources +
        </div>
      </a>
    </div>
    <div class="flex p-1 gap-2">
      <a target="_self" href="/talk-to-our-team">
        <button class="secondary"> Sign in </button>
      </a>
      <a href="/talk-to-our-team">
        <button class="primary"> Try for free </button>
      </a>
    </div>
  </div>
</div>
