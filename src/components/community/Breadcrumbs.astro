---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
  current: string;
}

const { items, current } = Astro.props as Props;
---

<nav aria-label="Breadcrumb" class="text-sm text-stone-500 dark:text-stone-400">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item) => (
      <li class="flex items-center gap-2">
        <a
          href={item.href}
          class="hover:text-stone-700 dark:hover:text-stone-200 transition-colors"
          data-astro-prefetch
        >
          {item.label}
        </a>
        <span aria-hidden="true">/</span>
      </li>
    ))}
    <li class="text-stone-700 dark:text-stone-200" aria-current="page">
      {current}
    </li>
  </ol>
</nav>
