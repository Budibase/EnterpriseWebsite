---
import Tag from "@components/Tag.astro";

interface Props {
  href: string;
  title: string;
  outcome: string;
  tags: string[];
  setupTime: string;
  difficulty: "Easy" | "Medium" | "Easy-Medium";
  sourceType: "official" | "community";
}

const {
  href,
  title,
  outcome,
  tags,
  setupTime,
  difficulty,
  sourceType,
} = Astro.props as Props;

const sourceLabel = sourceType === "official" ? "Official" : "Community";
const sourceVariant = sourceType === "official" ? "secondary" : "orange";
const difficultyLabel =
  difficulty === "Easy-Medium" ? `Easy\u2013Medium` : difficulty;
---

<a
  href={href}
  class="group block h-full rounded-xl border border-stone-200/70 dark:border-stone-800/70 bg-secondary p-4 md:p-5 transition-all duration-150 hover:-translate-y-0.5 hover:border-stone-300 dark:hover:border-stone-700 hover:shadow-sm"
  data-astro-prefetch
>
  <div class="flex flex-col gap-3 h-full">
    <div class="flex items-center gap-2">
      <Tag label={sourceLabel} variant={sourceVariant} size="extra-small" />
      <span class="text-xs text-stone-500 dark:text-stone-400">
        Setup {setupTime}
      </span>
    </div>

    <div>
      <h3 class="text-lg font-semibold text-stone-900 dark:text-stone-100">
        {title}
      </h3>
      <p class="text-sm text-stone-600 dark:text-stone-400 mt-1">
        {outcome}
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <Tag label={tag} variant="secondary" size="extra-small" />
      ))}
    </div>

    <div class="flex items-center justify-between text-xs text-stone-500 dark:text-stone-400">
      <span>Difficulty {difficultyLabel}</span>
      <span class="text-stone-700 dark:text-stone-200 font-medium">
        View workflow
      </span>
    </div>
  </div>
</a>
