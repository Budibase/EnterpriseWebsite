---
import Tag from "@components/Tag.astro";

interface Props {
  index: number;
  title: string;
  description: string;
  humanDecision?: boolean;
}

const { index, title, description, humanDecision = false } =
  Astro.props as Props;
---

<li class="flex gap-4">
  <div class="flex flex-col items-center">
    <div class="h-8 w-8 rounded-full bg-stone-200 dark:bg-stone-800 text-stone-700 dark:text-stone-200 flex items-center justify-center text-sm font-semibold">
      {index}
    </div>
    <div class="flex-1 w-px bg-stone-200 dark:bg-stone-800 mt-2"></div>
  </div>
  <div class="pb-6">
    <div class="flex items-center gap-2">
      <h3 class="text-base font-semibold text-stone-900 dark:text-stone-100">
        {title}
      </h3>
      {humanDecision && (
        <Tag label="Human decision" variant="orange" size="extra-small" />
      )}
    </div>
    <p class="text-sm text-stone-600 dark:text-stone-400 mt-1">
      {description}
    </p>
  </div>
</li>
