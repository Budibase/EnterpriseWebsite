---
import { Image } from "astro:assets";
import TeamsLogo from "@assets/logos/microsoft-teams.svg";
import BambooHrLogo from "@assets/logos/bamboohr.svg";
import ClockFill from "phosphor-astro/ClockFill.astro";
import RowsPlusBottomFill from "phosphor-astro/RowsPlusBottomFill.astro";
import PaperPlaneTiltFill from "phosphor-astro/PaperPlaneTiltFill.astro";
import SparkleFill from "phosphor-astro/SparkleFill.astro";
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import TitleBlock from "@components/TitleBlock.astro";

interface FrameNode {
  title: string;
  description?: string;
  iconKind: "sparkle" | "clock" | "rowsPlusBottom" | "paperPlaneTilt" | "teams" | "bamboohr";
  iconTone: "trigger" | "agent" | "integration" | "alert";
  badgeLabel?: "Trigger" | "Operation";
  badgeTone?: "trigger" | "operation";
}

interface FrameScenario {
  id: "teams-alert" | "whos-out" | "release-notes" | "offboard";
  nodes: FrameNode[];
}

const id = `app-process-outcome-${Math.random().toString(36).slice(2, 8)}`;

const frames: FrameScenario[] = [
  {
    id: "teams-alert",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Agent trigger",
        description: "This automation is triggered by agents",
        iconKind: "sparkle",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Microsoft Teams",
        description: "Send alert message to #ITOps channel",
        iconKind: "teams",
        iconTone: "integration",
      },
    ],
  },
  {
    id: "whos-out",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Schedule",
        description: "Everyday at 8am",
        iconKind: "clock",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "API connector",
        description: "Check who is on annual leave",
        iconKind: "bamboohr",
        iconTone: "integration",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Broadcast Agent",
        description: "Fetch who is on annual leave and send a message to Slack",
        iconKind: "sparkle",
        iconTone: "agent",
      },
    ],
  },
  {
    id: "release-notes",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Schedule",
        description: "Everyday at 8am",
        iconKind: "clock",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Github Agent",
        description: "Fetch releases",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Broadcast Agent",
        description: "Create release notes and send a message to Slack",
        iconKind: "sparkle",
        iconTone: "agent",
      },
    ],
  },
  {
    id: "offboard",
    nodes: [
      {
        badgeLabel: "Trigger",
        badgeTone: "trigger",
        title: "Submission",
        description: "Offboarding_Table",
        iconKind: "rowsPlusBottom",
        iconTone: "trigger",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Offboard Agent",
        description: "Revoke permissions from Slack, Okta, and Jira",
        iconKind: "sparkle",
        iconTone: "agent",
      },
      {
        badgeLabel: "Operation",
        badgeTone: "operation",
        title: "Alert manager",
        description: "Send confirmation email to manager",
        iconKind: "paperPlaneTilt",
        iconTone: "alert",
      },
    ],
  },
];
---

<section id={id} class="mt-12 md:mt-16">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20">
    <div>
      <div class="app-process-outcome-canvas rounded-xl px-4 py-5 sm:px-5 sm:py-6">
        <div data-flow-content class="app-process-outcome-flow-content">
          {
            frames.map((frame, frameIndex) => (
              <ul
                class:list={[
                  "app-process-outcome-node-list",
                  frame.id === "teams-alert" && "is-frame-teams-alert",
                  frameIndex === 0 && "is-active",
                ]}
                data-frame-list
                data-frame-id={frame.id}
                data-frame-index={frameIndex}
                aria-hidden={frameIndex === 0 ? "false" : "true"}
              >
                {
                  frame.nodes.map((node) => (
                    <li class="app-process-outcome-node-wrap">
                      {node.badgeLabel && (
                        <span
                          class:list={[
                            "app-process-outcome-node-badge",
                            node.badgeTone === "operation"
                              ? "is-operation"
                              : "is-trigger",
                          ]}
                        >
                          {node.badgeLabel}
                        </span>
                      )}

                      <div class="app-process-outcome-node">
                        <span
                          class:list={[
                            "app-process-outcome-node-icon",
                            `is-${node.iconTone}`,
                          ]}
                          aria-hidden="true"
                        >
                          {node.iconKind === "sparkle" && <SparkleFill class="h-[18px] w-[18px]" />}
                          {node.iconKind === "clock" && <ClockFill class="h-[18px] w-[18px]" />}
                          {node.iconKind === "rowsPlusBottom" && (
                            <RowsPlusBottomFill class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "paperPlaneTilt" && (
                            <PaperPlaneTiltFill class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "teams" && (
                            <Image src={TeamsLogo} alt="Microsoft Teams" class="h-[18px] w-[18px]" />
                          )}
                          {node.iconKind === "bamboohr" && (
                            <Image src={BambooHrLogo} alt="BambooHR" class="h-[18px] w-[18px]" />
                          )}
                        </span>

                        <div class="app-process-outcome-node-copy">
                          <div class="app-process-outcome-node-title">{node.title}</div>
                          {node.description && <p class="app-process-outcome-node-description">{node.description}</p>}
                        </div>
                      </div>
                    </li>
                  ))
                }
              </ul>
            ))
          }
        </div>
      </div>
    </div>

    <div>
      <TitleBlock
        variant="section"
        containerClass="flex flex-col gap-2"
        titleColorMode="split-secondary-primary"
        titleLines={[
          { text: "Turn messy processes" },
          { text: "into simple apps" },
        ]}
        titleClass="m-0 max-w-xl"
      />
      <p class="hero-description-small app-process-outcome-description max-w-xl">
        Growing businesses run on requests, approvals, and internal processes but too often those live in
        spreadsheets, inboxes, or Slack threads. Within Budibase, you can turn those processes into simple internal
        apps your team can rely on.
      </p>

      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Collect requests with forms
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Track work in structured workflows
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Give teams one place to manage operations - no engineering required.
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .app-process-outcome-canvas {
    --app-process-outcome-grid-dot: rgb(var(--border) / 0.45);
    --app-process-outcome-connector: rgb(var(--ring) / 0.72);
    --app-process-outcome-node-bg: var(--bg-3);
    --app-process-outcome-node-integration-bg: var(--grey-700);
    --app-process-outcome-trigger-bg: var(--orange-500);
    --app-process-outcome-operation-bg: var(--purple-500);
    --app-process-outcome-agent-bg: var(--blue-500);
    --app-process-outcome-node-title: var(--text-primary);
    --app-process-outcome-node-description: var(--text-secondary);
    --app-process-outcome-node-icon-fg: #fff;
    --app-process-outcome-badge-fg: rgb(var(--text));
    background:
      radial-gradient(circle at center, var(--app-process-outcome-grid-dot) 1px, transparent 1px) 0 0 / 20px
        20px,
      var(--bg-2);
  }

  .app-process-outcome-flow-content {
    position: relative;
    width: 100%;
    max-width: 380px;
    height: 512px;
    margin: 0 auto;
    transition:
      opacity 180ms ease,
      transform 220ms ease;
  }

  .app-process-outcome-flow-content.is-swapping {
    opacity: 0;
    transform: translateY(5px);
  }

  .app-process-outcome-node-list {
    --node-width: 380px;
    --node-row-gap: 60px;
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--node-row-gap);
    justify-content: center;
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .app-process-outcome-node-list.is-frame-teams-alert {
    --node-width: 380px;
  }

  .app-process-outcome-node-list.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .app-process-outcome-node-wrap {
    position: relative;
    width: var(--node-width);
  }

  .app-process-outcome-node-wrap:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 50%;
    top: calc(100% + 8px);
    width: 1px;
    height: calc(var(--node-row-gap) - 16px);
    transform: translateX(-50%);
    background-image: linear-gradient(to bottom, var(--app-process-outcome-connector) 45%, transparent 45%);
    background-size: 1px 8px;
    background-repeat: repeat-y;
    animation: app-process-outcome-march 700ms linear infinite;
  }

  .app-process-outcome-node-badge {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: #fff;
    padding: 2px 4px;
    font-size: 14px;
    font-weight: 500;
    line-height: 17px;
  }

  .app-process-outcome-node-badge.is-trigger {
    background: var(--app-process-outcome-trigger-bg);
  }

  .app-process-outcome-node-badge.is-operation {
    background: var(--app-process-outcome-operation-bg);
  }

  .app-process-outcome-node {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 48px;
    align-items: flex-start;
    gap: 10px;
    border-radius: 6px;
    border: none;
    background: var(--app-process-outcome-node-bg);
    padding: 8px 12px;
  }

  .app-process-outcome-node-icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    color: var(--app-process-outcome-node-icon-fg);
  }

  .app-process-outcome-node-icon.is-trigger {
    background: var(--app-process-outcome-trigger-bg);
  }

  .app-process-outcome-node-icon.is-agent {
    background: var(--app-process-outcome-agent-bg);
  }

  .app-process-outcome-node-icon.is-integration {
    background: var(--app-process-outcome-node-integration-bg);
  }

  .app-process-outcome-node-icon.is-alert {
    background: var(--app-process-outcome-operation-bg);
  }

  .app-process-outcome-node-copy {
    min-width: 0;
    flex: 1;
  }

  .app-process-outcome-node-title {
    margin: 0;
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 500;
    line-height: 22px;
  }

  .app-process-outcome-node-description {
    margin: 0;
    color: var(--app-process-outcome-node-description);
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
  }

  .app-process-outcome-description {
    margin-top: 20px;
    margin-bottom: 20px;
  }

  @keyframes app-process-outcome-march {
    from {
      background-position-y: 0;
    }
    to {
      background-position-y: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-process-outcome-flow-content {
      transition: none;
    }

    .app-process-outcome-node-wrap:not(:last-child)::after {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .app-process-outcome-canvas {
      padding: 16px;
    }

    .app-process-outcome-flow-content {
      height: 512px;
    }

    .app-process-outcome-node-list {
      width: 100%;
    }

    .app-process-outcome-node-wrap,
    .app-process-outcome-node-list.is-frame-teams-alert .app-process-outcome-node-wrap {
      width: min(100%, var(--node-width));
    }

    .app-process-outcome-node {
      width: 100%;
      min-height: 46px;
    }
  }
</style>

<script define:vars={{ id }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const flowContent = root.querySelector("[data-flow-content]");
    const frameLists = Array.from(root.querySelectorAll("[data-frame-list]"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (frameLists.length === 0) return;

    const FRAME_INTERVAL_MS = 5000;
    const SWAP_DURATION_MS = 180;

    let activeIndex = 0;
    let loopTimer = null;
    let swapTimer = null;

    function setActiveFrame(index) {
      const normalizedIndex = ((index % frameLists.length) + frameLists.length) % frameLists.length;

      frameLists.forEach((frame, frameIndex) => {
        const isActive = frameIndex === normalizedIndex;
        frame.classList.toggle("is-active", isActive);
        frame.setAttribute("aria-hidden", isActive ? "false" : "true");
      });

      activeIndex = normalizedIndex;
    }

    function stopLoop() {
      if (loopTimer) {
        window.clearInterval(loopTimer);
        loopTimer = null;
      }
      if (swapTimer) {
        window.clearTimeout(swapTimer);
        swapTimer = null;
      }
    }

    function swapToFrame(index, options = { animate: true }) {
      const { animate } = options;

      if (!animate || prefersReducedMotion.matches) {
        flowContent?.classList.remove("is-swapping");
        setActiveFrame(index);
        return;
      }

      flowContent?.classList.add("is-swapping");

      if (swapTimer) {
        window.clearTimeout(swapTimer);
      }

      swapTimer = window.setTimeout(() => {
        setActiveFrame(index);
        flowContent?.classList.remove("is-swapping");
      }, SWAP_DURATION_MS);
    }

    function startLoop() {
      stopLoop();
      loopTimer = window.setInterval(() => {
        swapToFrame(activeIndex + 1, { animate: true });
      }, FRAME_INTERVAL_MS);
    }

    function handleMotionChange() {
      if (prefersReducedMotion.matches) {
        stopLoop();
        flowContent?.classList.remove("is-swapping");
        setActiveFrame(0);
        return;
      }

      startLoop();
    }

    if (typeof prefersReducedMotion.addEventListener === "function") {
      prefersReducedMotion.addEventListener("change", handleMotionChange);
    } else if (typeof prefersReducedMotion.addListener === "function") {
      prefersReducedMotion.addListener(handleMotionChange);
    }

    setActiveFrame(0);

    if (!prefersReducedMotion.matches) {
      startLoop();
    }
  })();
</script>
