---
export const prerender = false;

import { getCollection } from "astro:content";

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join("/") : slugParam;

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const caseStudies = await getCollection("caseStudies");

return new Response(JSON.stringify({
  slugParam,
  slug,
  blogIdsSample: blogPosts.slice(0, 20).map((entry) => entry.id),
  hasExactBlogMatch: blogPosts.some((entry) => entry.id === slug),
  hasExactCaseStudyMatch: caseStudies.some((entry) => entry.id === slug),
}, null, 2), {
  status: 200,
  headers: { "Content-Type": "application/json" },
});
---

<MarkdownPostLayout frontmatter={frontmatter} transitionKey={transitionKey}>
  <article class="article my-8 max-w-2xl mx-auto">
    {
      kind === "caseStudy" && (
        <div class="mb-4 text-sm text-stone-500 dark:text-stone-400">Customers</div>
      )
    }
    {hasHugoShortcodes ? <Fragment set:html={shortcodeHtml} /> : Content && <Content />}
  </article>
  <CTA />
</MarkdownPostLayout>
