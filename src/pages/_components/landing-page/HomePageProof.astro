---
import SectionBlock from "@components/SectionBlock.astro";
import Button from "@components/Button.astro";
---
<section class="container max-w-7xl mx-auto mt-12 md:mt-24 px-2 lg:px-0">
  <SectionBlock
    title="Time is money. Save both."
    description="Established governments to industry leaders use Budibase to transform
      workflows and build faster businesses."
    align="center"
    maxWidth="3xl"
  >
  <div class="benefits-grid">
    <div class="benefits-grid-featured bg-base-18">
      <div class="featured_wrapper">
        <div class="featured-content">
          <div class="icon-container-lg mb-3 mx-auto bg-bb-lime">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="black"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20.91 8.84 8.56 2.23a1.93 1.93 0 0 0-1.81 0L3.1 4.13a2.12 2.12 0 0 0-.05 3.69l12.22 6.93a2 2 0 0 0 1.94 0L21 12.51a2.12 2.12 0 0 0-.09-3.67Z"
              ></path>
              <path
                d="m3.09 8.84 12.35-6.61a1.93 1.93 0 0 1 1.81 0l3.65 1.9a2.12 2.12 0 0 1 .1 3.69L8.73 14.75a2 2 0 0 1-1.94 0L3 12.51a2.12 2.12 0 0 1 .09-3.67Z"
              ></path>
              <line x1="12" y1="22" x2="12" y2="13"></line>
              <path
                d="M20 13.5v3.37a2.06 2.06 0 0 1-1.11 1.83l-6 3.08a1.93 1.93 0 0 1-1.78 0l-6-3.08A2.06 2.06 0 0 1 4 16.87V13.5"
              ></path>
            </svg>
          </div>
          <p class="detail text-dark opacity-75 text-center text-white">
            Proud to be
          </p>
          <h3 class="h1 mb-3 font-weight-bold text-white">Open source</h3>
          <p class="text-center text-white">
            Budibase is open source, allowing you to transform operations within
            the security of your own infrastructure.
          </p>
        </div>
      <div class="platform-hero__cta">
        <Button
          label="Try it free"
          url="https://account.budibase.app/register"
          variant="primary"
          size="large"
          class="px-6 py-3 text-xl md:px-7 md:py-3.5 md:text-xl"
          target="_blank"
        />
      </div>
      </div>
    </div>
    <div class="benefits-grid-major-0 bg-base-2">
      <a href="/blog/reworld">
        <div class="benefits-design-wrapper mt-4 mt-lg-0">
          <div class="benefits-automate-content">
            <div class="icon-container-lg mb-2 bg-bb-lime">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="black"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="12" y1="2" x2="12" y2="22"></line>
                <path
                  d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                ></path>
              </svg>
            </div>
            <h3 class="h4 mb-1 font-weight-semi-bold text-center">
              $3m in annual savings
            </h3>
            <p class="text-center font-weight-normal">
              Reworld expect to make $3m in annual savings by reducing data
              entry
            </p>
          </div>
        </div>
      </a>
    </div>
    <div class="benefits-grid-major-1 bg-base-2">
      <a href="/blog/bulgarian-government">
        <div class="benefits-design-wrapper">
          <div class="benefits-automate-content mt-4 mt-lg-0">
            <div class="icon-container-lg mb-2 bg-bb-lime">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="black"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
                ></path>
                <path
                  d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
                ></path>
                <path d="M7 21h10"></path>
                <path d="M12 3v18"></path>
                <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"></path>
              </svg>
            </div>
            <h3 class="h4 mb-1 font-weight-semi-bold">
              Scale to 100,000 users
            </h3>
            <p class="text-center font-weight-normal">
              The Bulgarian Gov created an app in 4 days and scaled it to
              100,000+ users.
            </p>
          </div>
        </div>
      </a>
    </div>
    <div class="benefits-grid-minor-0 bg-base-2">
      <a href="/blog/schnellecke">
        <div class="benefits-automate-wrapper">
          <div class="benefits-automate-content mt-2">
            <div class="icon-container-lg mb-2 bg-bb-lime">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="black"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polygon points="13 19 22 12 13 5 13 19"></polygon>
                <polygon points="2 19 11 12 2 5 2 19"></polygon>
              </svg>
            </div>
            <h3 class="h4 font-weight-semi-bold">Speed up dev by 90%</h3>
            <p class="text-center font-weight-normal">
              With Budibase, Schnellecke are now 90% faster at building internal
              tools
            </p>
          </div>
        </div>
      </a>
    </div>
    <div class="benefits-grid-minor-1 bg-base-2">
      <div class="benefits-design-wrapper">
        <div class="benefits-content mt-4">
          <div class="icon-container-lg bg-bb-lime">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"
              ></path>
            </svg>
          </div>
          <p class="text-center font-weight-normal">
            Budibase helps you create apps faster which devs love because their
            internal tickets disappear.
          </p>
          <p class="text-xs"><i>Shawn (@swyx)</i></p>
        </div>
      </div>
    </div>
  </div>
  </SectionBlock>
</section>

<style>
.benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: 260px 260px;
  gap: 24px;
  align-items: stretch;
}

.benefits-grid-featured {
  grid-column: 1;
  grid-row: 1 / span 2;
  background: #000;
  color: #fff;
  border-radius: 12px;
  padding: 32px;
  overflow: hidden;
}

.featured_wrapper {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.featured-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.benefits-grid-major-0,
.benefits-grid-major-1,
.benefits-grid-minor-0,
.benefits-grid-minor-1 {
  background: var(--bg-2, #f4f4f5);
  color: #111;
  border-radius: 12px;
  padding: 24px;
  overflow: hidden;
}

.benefits-grid-major-0 {
  grid-column: 2;
  grid-row: 1;
}

.benefits-grid-major-1 {
  grid-column: 3;
  grid-row: 1;
}

.benefits-grid-minor-0 {
  grid-column: 2;
  grid-row: 2;
}

.benefits-grid-minor-1 {
  grid-column: 3;
  grid-row: 2;
}

.benefits-grid a {
  display: block;
  height: 100%;
  color: inherit;
  text-decoration: none;
}

.benefits-design-wrapper,
.benefits-automate-wrapper {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.benefits-automate-content,
.benefits-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.benefits-grid-featured .btn-cta {
  margin-top: 24px;
  align-self: center;
}

.benefits-grid-featured .text-white,
.benefits-grid-featured h3,
.benefits-grid-featured p {
  color: #fff;
}

.benefits-grid-major-0 h3,
.benefits-grid-major-1 h3,
.benefits-grid-minor-0 h3,
.benefits-grid-minor-1 h3,
.benefits-grid-major-0 p,
.benefits-grid-major-1 p,
.benefits-grid-minor-0 p,
.benefits-grid-minor-1 p {
  color: #111;
}

.benefits-savings-image,
.benefits-automate-image {
  max-width: 100%;
  max-height: 120px;
  height: auto;
  object-fit: cover;
  border-radius: 12px;
  margin-top: 12px;
}

@media (max-width: 768px) {
  .benefits-grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
  }

  .benefits-grid-featured,
  .benefits-grid-major-0,
  .benefits-grid-major-1,
  .benefits-grid-minor-0,
  .benefits-grid-minor-1 {
    grid-column: auto;
    grid-row: auto;
  }
}

.platform-hero__cta {
  margin-top: 1.5rem;
  display: flex;
  justify-content: center;
}
</style>
