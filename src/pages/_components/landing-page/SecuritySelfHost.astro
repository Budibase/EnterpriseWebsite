---
import CheckCircleFill from "phosphor-astro/CheckCircleFill.astro";
import FormDemo from "@components/FormDemo.astro";
import SectionBlock from "@components/SectionBlock.astro";
---

<section>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:items-center lg:gap-20">
    <div>
      <FormDemo />
    </div>

    <SectionBlock
      titleColorMode="split-secondary-primary"
      titleLines={[
        { text: "Host Budibase" },
        { text: "within your own environment" },
      ]}
      description="Budibase is open-source and self-hostable, enabling teams to transform operations within their own secure environments."
      maxWidth="xl"
      spacing="default"
      contentClass="pt-1"
    >
      <ul class="m-0 flex flex-col gap-4">
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Open-source.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Deploy Budibase using Kubernetes, Docker, and more.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Air-gapped deployments.
          </div>
        </li>
            <li class="flex items-start gap-3">
          <CheckCircleFill class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--accent-blue)]" aria-hidden="true" />
          <div class="m-0 text-[15px] font-medium leading-6 text-[var(--text-primary)]">
            Included in Iron Bank.
          </div>
        </li>
      </ul>
    </SectionBlock>
  </div>
</section>
