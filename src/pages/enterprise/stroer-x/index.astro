---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { enterpriseNavItemsData } from "../_navItems";
import Buildings from "phosphor-astro/Buildings.astro";
import ShieldCheck from "phosphor-astro/ShieldCheck.astro";
import Sliders from "phosphor-astro/Sliders.astro";
import Headset from "phosphor-astro/Headset.astro";
import MapPin from "phosphor-astro/MapPin.astro";
import HardHat from "phosphor-astro/HardHat.astro";
import Broadcast from "phosphor-astro/Broadcast.astro";
import Recycle from "phosphor-astro/Recycle.astro";
import Truck from "phosphor-astro/Truck.astro";
import Bank from "phosphor-astro/Bank.astro";
import Gear from "phosphor-astro/Gear.astro";
import Package from "phosphor-astro/Package.astro";
import HeroBg from "@assets/images/homepage/valley.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const iconMap: Record<string, any> = {
	Buildings,
	ShieldCheck,
	Sliders,
	Headset,
	MapPin,
	HardHat,
	Broadcast,
	Recycle,
	Truck,
	Bank,
	Gear,
	Package,
};

const navItems = enterpriseNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));
---

<Layout>
	<PlatformLayout
		title="Enterprise"
		description="Enterprise-grade security, control, & support for mission-critical workflows."
		{navItems}
	>
		<div class="mb-8">
			<div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
				<h2 class="text-lg! text-stone-900 dark:text-stone-100">
					Ströer-x
				</h2>
				<p
					class="text-base! text-stone-600! dark:text-stone-400! mb-4! lg:max-w-lg"
				>
					See how Ströer-x, part of Germany's largest out-of-home media company, revolutionized their digital advertising operations with Budibase.
				</p>

				<Image
					src={HeroBg}
					alt="Ströer-x case study"
					class="w-full h-96 object-cover rounded-md"
				/>
			</div>

			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
			>
				<Card
					label="Media & Advertising"
					description="Leading digital out-of-home advertising network in Europe."
				/>
				<Card
					label="Campaign management"
					description="Streamlined ad campaign scheduling and performance tracking."
				/>
				<Card
					label="Inventory control"
					description="Real-time visibility into digital billboard inventory across Germany."
				/>
				<Card
					label="Client portals"
					description="Self-service portals for advertisers to manage their campaigns."
				/>
				<Card
					label="Analytics dashboard"
					description="Comprehensive reporting on ad performance and ROI metrics."
				/>
				<Card
					label="API integrations"
					description="Connected with programmatic advertising platforms and DSPs."
				/>
			</div>
		</div>
	</PlatformLayout>
</Layout>

