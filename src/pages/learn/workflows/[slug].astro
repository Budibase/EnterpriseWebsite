---
import Layout from "../../../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const workflows = await getCollection("workflows");
  return workflows.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, outcome, sidebar } = entry.data;
const { Content } = await render(entry);
---

<Layout title={`${title} Workflow Playbook | Budibase`} description={outcome}>
  <section class="pt-20 pb-10">
    <div class="container max-w-5xl mx-auto px-4">
      <h1 class="text-3xl md:text-5xl font-semibold text-stone-900 dark:text-stone-100">
        {title} Workflow
      </h1>
      <p class="text-base md:text-lg text-stone-600 dark:text-stone-400 mt-3 max-w-3xl">
        {outcome}
      </p>
      <p class="text-sm text-stone-500 dark:text-stone-400 mt-4">
        Runs in your environment. Humans stay in control.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[260px_minmax(0,1fr)]">
        <aside class="lg:sticky lg:top-24">
          <div class="rounded-lg border-[1px] border-border/60 bg-2 p-4 lg:p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-muted">
              Build steps
            </p>
            <nav aria-label="Build steps">
              <ol class="mt-4 flex gap-2 overflow-x-auto pb-2 lg:flex-col lg:gap-2 lg:overflow-visible lg:pb-0">
                {sidebar.map((item, index) => (
                  <li class="flex">
                    <a
                      class="group flex min-w-[180px] shrink-0 items-center gap-3 rounded-md border-[1px] border-transparent px-3 py-2 text-sm text-text-muted transition hover:text-text data-[active=true]:bg-surface data-[active=true]:border-border data-[active=true]:text-text data-[active=true]:font-semibold lg:min-w-0 lg:shrink"
                      href={`#${item.id}`}
                      data-step-link
                      data-step-id={item.id}
                      data-active={index === 0 ? "true" : "false"}
                    >
                      <span class="flex h-7 w-7 items-center justify-center rounded-full border-[1px] border-border/60 text-xs font-semibold text-text-muted">
                        {index + 1}
                      </span>
                      <span class="whitespace-nowrap lg:whitespace-normal">
                        {item.label}
                      </span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </aside>

        <article class="max-w-3xl [&_h2]:scroll-mt-24">
          <Content />
        </article>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ ids: sidebar.map((item) => item.id) }}>
  (() => {
    if (!Array.isArray(ids) || ids.length === 0) return;

    const links = Array.from(document.querySelectorAll("[data-step-link]"));
    const sections = ids
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    if (links.length === 0 || sections.length === 0) return;

    function setActive(id) {
      links.forEach((link) => {
        const isActive = link.getAttribute("data-step-id") === id;
        link.dataset.active = isActive ? "true" : "false";
        if (isActive) {
          link.setAttribute("aria-current", "true");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    }

    const initialHash = window.location.hash.replace("#", "");
    if (initialHash && ids.includes(initialHash)) {
      setActive(initialHash);
    } else {
      setActive(ids[0]);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: "0px 0px -60% 0px",
        threshold: 0.25,
      },
    );

    sections.forEach((section) => observer.observe(section));

    window.addEventListener("hashchange", () => {
      const hash = window.location.hash.replace("#", "");
      if (hash && ids.includes(hash)) setActive(hash);
    });
  })();
</script>
