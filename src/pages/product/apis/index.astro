---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { getProductPageMeta } from "../_pageMeta";
import Card from "@components/cards/Card.astro";
import APIExplorerDemo from "@components/APIExplorerDemo.astro";
import APIsBackdrop from "@assets/images/backgrounds/light/api.png";

const { title: pageTitle, description: pageDescription } = getProductPageMeta(
  Astro.url.pathname,
);
---

<Layout title={pageTitle} description={pageDescription}>
  <PlatformLayout title={pageTitle} description={pageDescription}>
    <div class="mb-8">
      <div class="mb-4">
        <div class="api-explorer-demo-plain">
          <APIExplorerDemo
            backdropImage={APIsBackdrop.src}
            backdropPaddingXClass="px-12"
          />
        </div>
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
      >
        <Card
          label="Beautiful interface for making API requests"
          description="Interact with APIs through a clean, intuitive UI."
        />
        <Card
          label="100 API templates"
          description="Get started fast with ready-made templates for popular services."
        />
        <Card
          label="Multiple auth types support"
          description="Authenticate securely using Basic, Bearer, or OAuth2."
        />
        <Card
          label="Test requests within the API explorer"
          description="Validate APIs instantly without external tools."
        />
        <Card
          label="Control access to APIs (RBAC)"
          description="Manage who can access which APIs with fine-grained permissions."
        />
        <Card
          label="Quickly see where your API is getting used"
          description="Understand usage and dependencies at a glance."
        />
      </div>
    </div>
  </PlatformLayout>
</Layout>

<style>
  .api-explorer-demo-plain :global(.api-explorer-demo-backdrop::before) {
    background: rgb(var(--bg) / 0.45);
  }
</style>
