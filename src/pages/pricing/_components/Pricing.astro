  <script is:inline>
    if (typeof window !== "undefined") {
      const cloudButton = document.querySelector('[data-plan="cloud"]');
      const selfHostButton = document.querySelector('[data-plan="self-host"]');
      const cloudSection = document.querySelector('[data-section="cloud"]');
      const selfHostSection = document.querySelector(
        '[data-section="self-host"]',
      );

      if (cloudButton && selfHostButton && cloudSection && selfHostSection) {
        const setButtonState = (button, isActive) => {
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
          if (isActive) {
            button.classList.add("bg-white");
            button.classList.remove("bg-transparent");
          } else {
            button.classList.add("bg-transparent");
            button.classList.remove("bg-white");
          }
        };

        const showCloud = () => {
          cloudSection.removeAttribute("hidden");
          selfHostSection.setAttribute("hidden", "");
          setButtonState(cloudButton, true);
          setButtonState(selfHostButton, false);
        };

        const showSelfHost = () => {
          selfHostSection.removeAttribute("hidden");
          cloudSection.setAttribute("hidden", "");
          setButtonState(selfHostButton, true);
          setButtonState(cloudButton, false);
        };

        cloudButton.addEventListener("click", (event) => {
          event.preventDefault();
          showCloud();
        });

        selfHostButton.addEventListener("click", (event) => {
          event.preventDefault();
          showSelfHost();
        });

        showCloud();
      }
    }
  </script>
