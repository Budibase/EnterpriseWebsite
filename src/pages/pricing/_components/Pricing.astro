---
import HardDrives from "phosphor-astro/HardDrives.astro";
import PlusCircle from "phosphor-astro/PlusCircleFill.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import CloudPlans from "./Cloud.astro";
import SelfHost from "./SelfHost.astro";
