---
/* removed self-host switcher imports */
import PricingCard from "./PricingCard.astro";
import AddOnsCard from "./AddOnsCard.astro";
---

<section class="container max-w-7xl mx-auto flex flex-col mt-12 md:mt-24 px-2 lg:px-0">
  <!--Title section -->
  <div class="flex flex-col items-center text-center">
    <h1 class="max-w-2xl text-2xl md:text-3xl lg:text-4xl mb-4 text-stone-950 dark:text-stone-100">
      Pricing
    </h1>
  </div>
  <div class="w-full flex flex-col gap-2">
    <div class="flex flex-row gap-2 mb-4 justify-center">
      <!-- Deployment Type Switcher -->
      <ul class="inline-flex flex-row bg-secondary rounded-[20px] p-1" id="deployment-switcher">
        <li>
          <button
            id="self-hosted-button"
            data-deployment="self-hosted"
            aria-pressed="true"
            class="bg-white dark:bg-stone-800 rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2"
          >
            Self-hosted
          </button>
        </li>
        <li>
          <button
            id="budibase-hosted-button"
            data-deployment="cloud"
            aria-pressed="false"
            class="bg-transparent rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2"
          >
            Budibase Hosted
          </button>
        </li>
      </ul>
      <!-- Yearly/Monthly Toggle (hidden by default, shown only for cloud) -->
      <ul class="flex-row bg-secondary rounded-[20px] p-1 hidden" id="billing-toggle">
        <li>
          <button
            id="annual-button"
            data-billing="annual"
            aria-pressed="true"
            class="bg-white dark:bg-stone-800 rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-900 dark:text-stone-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2"
          >
            Yearly
          </button>
        </li>
        <li>
          <button
            id="monthly-button"
            data-billing="monthly"
            aria-pressed="false"
            class="bg-transparent rounded-[19px] py-2 px-2 md:px-4 flex flex-row text-xs md:text-sm text-stone-600 dark:text-stone-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-500 dark:focus-visible:ring-stone-400 focus-visible:ring-offset-2"
          >
            Monthly
          </button>
        </li>
      </ul>
    </div>

    <!-- Self-Hosted Plans -->
    <section class="mb-12 md:mb-20" id="self-hosted-plans">
      <div class="grid grid-cols-1 md:grid-cols-[max-content_max-content] gap-5 justify-center">
        <div class="min-w-[420px]">
          <PricingCard
            title="Community"
            description="Includes:"
            creatorPrice="Free"
            creatorUnit=""
            creatorLabel=""
            recommended={false}
            buttonLabel="Install on-prem"
            buttonVariant="primary"
            buttonUrl="https://docs.budibase.com/docs/docker"
            buttonTarget="_blank"
            features={[
              "Unlimited users",
              "SSO",
              "Custom RBAC",
            ]}
          />
        </div>
        <div class="min-w-[420px]">
          <PricingCard
            title="Enterprise"
            description="Everything in Community, plus:"
            creatorPrice="From $15,000"
            creatorUnit="/ year"
            creatorLabel=""
            recommended={false}
            buttonLabel="Contact sales"
            buttonVariant="primary"
            buttonUrl="/signup-plus"
            features={[
              "Bulk discounts",
              "Enforced SSO",
              "On-premise / Cloud",
              "Active directory / SCIM",
              "Env variables",
              "Dedicated Support",
              "Audit Logs",
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Cloud Plans -->
    <section class="mb-12 md:mb-20 hidden" id="cloud-plans">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-3">
        <PricingCard
          title="Pro"
          description="Includes:"
          creatorPrice={10}
          userPrice={2}
          billingPlan="pro"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={false}
          buttonLabel="Start 14 day free trial"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          features={[
            "1 Workspace",
            "10k Automation runs",
            "Custom RBAC",
            "Custom branding",
            "SSO",
          ]}
        />
        <PricingCard
          title="Premium"
          description="Everything in Pro, plus:"
          creatorPrice={50}
          userPrice={5}
          billingPlan="premium"
          creatorUnit="/ month"
          userUnit="/ month"
          creatorLabel="per creator"
          userLabel="per end user"
          recommended={true}
          buttonLabel="Start 14 day free trial"
          buttonVariant="cta"
          buttonUrl="/signup-plus"
          features={[
            "Multiple workspaces",
            "100k Automation runs",
            "User groups",
            "Synchronous automations",
            "Backups",
          ]}
        />
        <PricingCard
          title="Enterprise"
          description="Everything in Premium, plus:"
          creatorPrice="From $7,500"
          creatorUnit="/ year"
          creatorLabel=""
          recommended={false}
          buttonLabel="Contact sales"
          buttonVariant="primary"
          buttonUrl="/signup-plus"
          features={[
            "Bulk discounts",
            "Enforced SSO",
            "On-premise / Cloud",
            "Active directory / SCIM",
            "Env variables",
            "Dedicated Support",
            "Audit Logs",
          ]}
        />
      </div>
    </section>
    <section class="my-8">
      <p class="text-xl md:text-2xl! pb-6 text-stone-900 dark:text-stone-100">Enterprise add-ons</p>
      <AddOnsCard label="Airgapped deployment" price="$10,000 per year" />
      <AddOnsCard label="1 business day SLA" price="$20,000 per year" />
      <AddOnsCard label="Professional services" price="$500 per day" />
    </section>
  </div>
</section>

<script>
  // Deployment type switching
  const deploymentButtons = document.querySelectorAll("[data-deployment]");
  const billingToggle = document.getElementById("billing-toggle");
  const selfHostedPlans = document.getElementById("self-hosted-plans");
  const cloudPlans = document.getElementById("cloud-plans");

  const activeClasses = [
    "bg-white",
    "dark:bg-stone-800",
    "text-stone-900",
    "dark:text-stone-100",
  ];
  const inactiveClasses = [
    "bg-transparent",
    "text-stone-600",
    "dark:text-stone-400",
  ];

  const applyDeploymentType = (deploymentType: string) => {
    deploymentButtons.forEach((button) => {
      const htmlButton = button as HTMLButtonElement;
      const isActive = htmlButton.dataset.deployment === deploymentType;
      htmlButton.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) => htmlButton.classList.toggle(className, isActive));
      inactiveClasses.forEach((className) => htmlButton.classList.toggle(className, !isActive));
    });

    if (deploymentType === "self-hosted") {
      // Show self-hosted plans, hide cloud plans and billing toggle
      selfHostedPlans?.classList.remove("hidden");
      cloudPlans?.classList.add("hidden");
      billingToggle?.classList.add("hidden");
      billingToggle?.classList.remove("inline-flex");
    } else {
      // Show cloud plans and billing toggle, hide self-hosted plans
      selfHostedPlans?.classList.add("hidden");
      cloudPlans?.classList.remove("hidden");
      billingToggle?.classList.remove("hidden");
      billingToggle?.classList.add("inline-flex");
    }
  };

  deploymentButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyDeploymentType(htmlButton.dataset.deployment || "self-hosted");
    });
  });

  // Billing toggle (yearly/monthly) - only for cloud plans
  const toggleButtons = document.querySelectorAll("[data-billing]");
  const cards = document.querySelectorAll("[data-billing-plan]");

  const formatPrice = (value: number) =>
    Number.isInteger(value) ? value.toString() : value.toFixed(2);

  const applyBilling = (billing: string) => {
    toggleButtons.forEach((button) => {
      const htmlButton = button as HTMLButtonElement;
      const isActive = htmlButton.dataset.billing === billing;
      htmlButton.setAttribute("aria-pressed", isActive ? "true" : "false");
      activeClasses.forEach((className) => htmlButton.classList.toggle(className, isActive));
      inactiveClasses.forEach((className) => htmlButton.classList.toggle(className, !isActive));
    });

    cards.forEach((card) => {
      card.querySelectorAll(".amount[data-base-price]").forEach((amountEl) => {
        const htmlEl = amountEl as HTMLElement;
        const basePrice = Number(htmlEl.dataset.basePrice);
        const multiplier = billing === "monthly" ? 1.2 : 1;
        const updatedPrice = basePrice * multiplier;
        htmlEl.textContent = `$${formatPrice(updatedPrice)}`;
      });
    });
  };

  toggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLButtonElement;
      applyBilling(htmlButton.dataset.billing || "annual");
    });
  });

  // Initialize: default to self-hosted
  applyDeploymentType("self-hosted");
  // Initialize billing for cloud plans (will be hidden initially)
  applyBilling("annual");
</script>
