---
import type { GetStaticPathsOptions, Page } from "astro";
import Pagination from "../../components/Pagination.astro";
import Layout from "../../layouts/MainLayout.astro";
import BlogTimelineRow from "../blog/_components/BlogTimelineRow.astro";
import {
  filterBlogFeed,
  getBlogFeedItems,
  type BlogFeedItem,
} from "../blog/_feed";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const feedItems = filterBlogFeed(await getBlogFeedItems(), "useCases");
  return paginate(feedItems, { pageSize: 12 });
}

interface Props {
  page: Page<BlogFeedItem>;
}

const { page } = Astro.props as Props;

const allPages = [...Array(page.lastPage).keys()].map((num) => {
  return `/use-cases${num === 0 ? "" : `/${String(num + 1)}`}`;
});
---

<Layout
  title="Use Cases"
  description="Workflow playbooks and practical AI use cases."
  image={{ src: "/og/blog.jpg", alt: "Budibase use cases" }}
>
  <div
    class="mx-auto mt-[clamp(5.6rem,8vw,7.2rem)] w-full max-w-[62rem] px-4 pb-16 max-md:mt-[max(calc(var(--site-nav-height)+1.1rem),4.8rem)] max-md:px-[0.9rem]"
  >
    <header class="mb-[1.4rem]">
      <h1
        class="hero-title m-0 font-['Fraunces'] text-[clamp(2.8rem,2.3rem+2vw,4.75rem)] leading-none tracking-[-0.02em] text-[var(--text-primary)]"
      >
        Use Cases
      </h1>
    </header>

    <main class="min-h-[60vh]">
      {
        page.data.length === 0 ? (
          <section class="rounded-[10px] border border-[var(--border-color)] bg-[var(--bg-2)] p-4">
            <p class="m-0 text-[var(--text-secondary)]">No use cases yet.</p>
          </section>
        ) : (
          <ul class="m-0 flex list-none flex-col p-0">
            {page.data.map((item, index) => (
              <li>
                <BlogTimelineRow
                  item={item}
                  showConnector={index < page.data.length - 1}
                />
              </li>
            ))}
          </ul>
        )
      }

      <div class="mt-4 w-full">
        <Pagination restRoute allPages={allPages} page={page} />
      </div>
    </main>
  </div>
</Layout>
