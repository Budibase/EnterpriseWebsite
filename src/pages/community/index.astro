---
import Layout from "../../layouts/MainLayout.astro";
import Button from "@components/Button.astro";
import CommunitySectionCard from "@components/community/CommunitySectionCard.astro";

const sections = [
  {
    title: "Workflow Playbooks",
    description: "Proven workflows you can clone and run.",
    href: "/community/workflows",
  },
  {
    title: "Tools",
    description: "Community-built tools and extensions.",
    status: "Coming soon",
  },
  {
    title: "Members",
    description: "Builders using Budibase in production.",
    status: "Coming soon",
  },
  {
    title: "Events",
    description: "Meetups, demos, and community calls.",
    status: "Coming soon",
  },
];
---

<Layout
  title="Community"
  description="Build faster together with workflows, tools, and people building real systems with Budibase."
>
  <section class="pt-24 pb-12">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400">
          Community
        </p>
        <h1 class="text-4xl md:text-5xl font-semibold text-stone-900 dark:text-stone-100 mt-3">
          Build faster together.
        </h1>
        <p class="text-base md:text-lg text-stone-600 dark:text-stone-400 mt-4">
          Workflows, tools, and people building real systems with Budibase.
        </p>
        <div class="flex flex-wrap gap-3 mt-6">
          <Button
            label="Explore Workflow Playbooks"
            url="/community/workflows"
            variant="primary"
            size="medium"
          />
          <Button
            label="Join Discord"
            url="#discord"
            variant="secondary"
            size="medium"
          />
          <Button
            label="Star on GitHub"
            url="#github"
            variant="secondary"
            size="medium"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {sections.map((section) => (
          <CommunitySectionCard
            title={section.title}
            description={section.description}
            href={section.href}
            status={section.status}
          />
        ))}
      </div>

      <div class="mt-10 text-sm text-stone-500 dark:text-stone-400">
        Open source. Self-hostable. Built for real workflows.
      </div>
    </div>
  </section>
</Layout>
