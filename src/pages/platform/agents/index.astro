---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { platformNavItemsData } from "../_navItems";
import Circles from "phosphor-astro/Nut.astro";
import Memory from "phosphor-astro/Memory.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import Path from "phosphor-astro/PathFill.astro";
import Browsers from "phosphor-astro/Browsers.astro";
import Link from "phosphor-astro/Cube.astro";
import Webhooks from "phosphor-astro/WebhooksLogo.astro";
import Database from "phosphor-astro/GridNine.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import TrendUp from "phosphor-astro/TrendUp.astro";
import ProductImage from "@assets/images/platform/AgentInstructions2.png";
import PreviewImage from "@assets/images/platform/AgentPreview.png";
import ToolsImage from "@assets/images/platform/AgentTools.png";
import LogsImage from "@assets/images/platform/AgentLogs.png";
import ChatImage from "@assets/images/platform/AgentInChat.png";
import AutomationImage from "@assets/images/platform/AgentInAutomations.png";
import { Image } from "astro:assets";
import Card from "@components/cards/Card.astro";

const iconMap: Record<string, any> = {
	Circles,
	Memory,
	ChatCircle,
	Path,
	Browsers,
	Link,
	Webhooks,
	Database,
	Sparkle,
	Cloud,
	TrendUp,
};

const navItems = platformNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));
---

<Layout>
  <PlatformLayout
    title="Platform"
    description="The privacy-first platform for building agents, chat, automations & apps."
    {navItems}
  >
    <div class="mb-8">
      <div class="bg-stone-100 dark:bg-stone-900 rounded-md p-4 mb-4">
        <h2 class="text-lg! text-stone-900 dark:text-stone-100">
          Agents
        </h2>
        <p
          class="text-base! text-stone-600! dark:text-stone-400! mb-4! lg:max-w-lg"
        >
          Design intelligent agents that reason, act, and integrate directly into your existing systems.
        </p>

        <Image
          src={ProductImage}
          alt="Agents editor"
          class="w-full h-96 object-cover rounded-md"
        />
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-2"
      >
        <Card
          label="Instructions"
          description="Define clear, reusable instructions that shape how your agents think and behave."
        />
        <Card
          label="Custom model support"
          description="Use the models you trust — from OpenAI to open-source — without compromise."
        />
        <Card
          label="Connect to over 100 tools"
          description="Give agents real capabilities by connecting them to your tools and services."
        />
        <Card
          label="Connect databases"
          description="Let agents read from and write to your data securely and reliably."
        />
        <Card
          label="Bring your own RAG"
          description="Plug in your own retrieval pipelines for precise, context-aware responses."
        />
        <Card
          label="Deploy agents"
          description="Use the same agent across automations, apps, and conversations."
        />
      </div>
    </div>
  </PlatformLayout>
</Layout>
