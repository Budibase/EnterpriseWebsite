---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import Code from "phosphor-astro/Code.astro";
import Wrench from "phosphor-astro/Wrench.astro";
import Eye from "phosphor-astro/Eye.astro";
import List from "phosphor-astro/List.astro";
import Rocket from "phosphor-astro/Rocket.astro";

const navItems = [
	{ text: "Editor", link: "#editor", sectionId: "editor", icon: Code },
	{ text: "Tools", link: "#tools", sectionId: "tools", icon: Wrench },
	{ text: "Preview", link: "#preview", sectionId: "preview", icon: Eye },
	{ text: "Logs", link: "#logs", sectionId: "logs", icon: List },
	{ text: "Deploy", link: "#deploy", sectionId: "deploy", icon: Rocket },
];
---

<Layout>
	<PlatformLayout
		title="Agents"
		description="The faster way to build AI agents with your models, data, and tools."
		{navItems}
	>
		<div id="editor-section" data-section="editor" class="content-section">
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Editor</h2>
			<p class="text-stone-600 dark:text-stone-400">Editor content goes here.</p>
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Editor</h2>
		</div>
		<div id="tools-section" data-section="tools" class="content-section">
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Tools</h2>
			<p class="text-stone-600 dark:text-stone-400">Tools content goes here.</p>
		</div>
		<div id="preview-section" data-section="preview" class="content-section">
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Preview</h2>
			<p class="text-stone-600 dark:text-stone-400">Preview content goes here.</p>
		</div>
		<div id="logs-section" data-section="logs" class="content-section">
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Logs</h2>
			<p class="text-stone-600 dark:text-stone-400">Logs content goes here.</p>
		</div>
		<div id="deploy-section" data-section="deploy" class="content-section">
			<h2 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">Deploy</h2>
			<p class="text-stone-600 dark:text-stone-400">Deploy content goes here.</p>
		</div>
	</PlatformLayout>
</Layout>
