---
import Layout from "../../../layouts/MainLayout.astro";
import PlatformLayout from "@components/PlatformLayout.astro";
import { platformNavItemsData } from "../_navItems";
import { Image } from "astro:assets";

// Nav icons
import Circles from "phosphor-astro/Nut.astro";
import Memory from "phosphor-astro/Memory.astro";
import ChatCircle from "phosphor-astro/ChatCircle.astro";
import Path from "phosphor-astro/PathFill.astro";
import Browsers from "phosphor-astro/Browsers.astro";
import Link from "phosphor-astro/Cube.astro";
import Webhooks from "phosphor-astro/WebhooksLogo.astro";
import Database from "phosphor-astro/GridNine.astro";
import Sparkle from "phosphor-astro/Sparkle.astro";
import Cloud from "phosphor-astro/Cloud.astro";
import TrendUp from "phosphor-astro/TrendUp.astro";

// Logos
import DiscordLogoSvg from "@assets/logos/discord.svg";

// Logos
import MistralLogo from "@assets/logos/Mistral.svg";
import OpenAILogo from "@assets/logos/openai.avif";
import GoogleLogo from "@assets/logos/Google.svg";
import BambooLogo from "@assets/logos/Bamboo.svg";
import OktaLogo from "@assets/logos/okta.jpeg";
import LlamaLogo from "@assets/logos/llama.svg";
import QwenLogo from "@assets/logos/qwen.svg";
import SlackLogo from "@assets/logos/Slack.svg";
import TeamsLogo from "@assets/logos/microsoft-teams.svg";
import JiraLogo from "@assets/logos/Jira.svg";
import PostgresLogo from "@assets/logos/Postgres.svg";
import MySQLLogo from "@assets/logos/MYSQL.svg";
import MSSQLLogo from "@assets/logos/MSSQL.svg";
import SnowflakeLogo from "@assets/logos/Snowflake.svg";
import OracleLogo from "@assets/logos/Oracle.svg";
import AzureOpenAILogo from "@assets/logos/azure-openai.svg";
import GeminiLogo from "@assets/logos/google-gemini.svg";
import GroqLogo from "@assets/logos/groq.png";
import AttioLogo from "@assets/logos/attio.png";
import AnthropicLogo from "@assets/logos/anthropic.avif";
import GithubLogoSvg from "@assets/logos/github.svg";
import GithubLogoWhite from "@assets/logos/githubWhite.png";
import TwilioLogo from "@assets/logos/twilio.svg";
import RestApiLogo from "@assets/logos/rest-api.svg";
import OpenApiLogo from "@assets/logos/openapi.svg";
import ExaLogo from "@assets/logos/exa.png";
import ServiceNowLogo from "@assets/logos/servicenow.svg";
import TavilyLogo from "@assets/logos/tavily.png";
import PagerDutyLogo from "@assets/logos/pagerduty.jpeg";
import StripeSvgLogo from "@assets/logos/stripe.svg";
import SmtpLogo from "@assets/logos/smtp.svg";
import DatadogLogo from "@assets/logos/datadog.svg";
import GoogleSheetsLogo from "@assets/logos/google-sheets.svg";
import CouchDBLogo from "@assets/logos/couchdb.svg";
import ElasticsearchLogo from "@assets/logos/elastic.svg";
import MongoDBLogo from "@assets/logos/mongodb.svg";
import DynamoDBLogo from "@assets/logos/amazon-dynamodb.svg";
import RedisLogo from "@assets/logos/redis.svg";
import FirestoreLogo from "@assets/logos/firestore.svg";
import AmazonS3Logo from "@assets/logos/amazon-s3.svg";

const iconMap: Record<string, any> = {
	Circles,
	Memory,
	ChatCircle,
	Path,
	Browsers,
	Link,
	Webhooks,
	Database,
	Sparkle,
	Cloud,
	TrendUp,
};

const navItems = platformNavItemsData.map(group => ({
	...group,
	items: group.items.map(item => ({
		...item,
		icon: iconMap[item.iconName],
	})),
}));
---

<Layout>
	<PlatformLayout
		title="Integrations"
		description="Connect Budibase with your favorite tools."
		{navItems}
	>
		<div class="mb-8 space-y-8">
			<!-- AI Models -->
			<section>
				<h2 class="text-lg! text-stone-900 dark:text-stone-100 mb-4">AI Models</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-2">
					<div class="integration-card">
						<Image src={MistralLogo} alt="Mistral" class="w-5 h-5" />
						<h3 class="text-base!">Mistral</h3>
					</div>
					<div class="integration-card">
						<Image src={OpenAILogo} alt="OpenAI" class="w-5 h-5" />
						<h3 class="text-base!">OpenAI</h3>
					</div>
				<div class="integration-card">
					<Image src={LlamaLogo} alt="Meta Llama" class="w-5 h-5" />
					<h3 class="text-base!">Meta Llama</h3>
				</div>
				<div class="integration-card">
					<Image src={QwenLogo} alt="Qwen" class="w-5 h-5" />
					<h3 class="text-base!">Qwen</h3>
				</div>
					<div class="integration-card">
						<Image src={AnthropicLogo} alt="Anthropic" class="w-5 h-5" />
						<h3 class="text-base!">Anthropic</h3>
					</div>
					<div class="integration-card">
						<Image src={GeminiLogo} alt="Google Gemini" class="w-5 h-5" />
						<h3 class="text-base!">Google Gemini</h3>
					</div>
					<div class="integration-card">
						<Image src={AzureOpenAILogo} alt="Azure OpenAI" class="w-5 h-5" />
						<h3 class="text-base!">Azure OpenAI</h3>
					</div>
					<div class="integration-card">
						<Image src={GroqLogo} alt="Groq" class="w-5 h-5" />
						<h3 class="text-base!">Groq</h3>
					</div>
				</div>
			</section>

			<!-- Tools and APIs -->
			<section>
				<h2 class="text-lg! text-stone-900 dark:text-stone-100 mb-4">Tools and APIs</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-2">
					<div class="integration-card">
						<Image src={BambooLogo} alt="Bamboo" class="w-5 h-5" />
						<h3 class="text-base!">Bamboo</h3>
					</div>
					<div class="integration-card">
						<Image src={ServiceNowLogo} alt="ServiceNow" class="w-5 h-5" />
						<h3 class="text-base!">ServiceNow</h3>
					</div>
					<div class="integration-card">
						<Image src={OktaLogo} alt="Okta" class="w-5 h-5" />
						<h3 class="text-base!">Okta</h3>
					</div>
					<div class="integration-card">
						<Image src={GithubLogoSvg} alt="GitHub" class="w-5 h-5 dark:hidden" />
						<Image src={GithubLogoWhite} alt="GitHub" class="w-5 h-5 hidden dark:block" />
						<h3 class="text-base!">GitHub</h3>
					</div>
					<div class="integration-card">
						<Image src={StripeSvgLogo} alt="Stripe" class="w-5 h-5" />
						<h3 class="text-base!">Stripe</h3>
					</div>
					<div class="integration-card">
						<Image src={SlackLogo} alt="Slack" class="w-5 h-5" />
						<h3 class="text-base!">Slack</h3>
					</div>
					<div class="integration-card">
						<Image src={DiscordLogoSvg} alt="Discord" class="w-5 h-5" />
						<h3 class="text-base!">Discord</h3>
					</div>
					<div class="integration-card">
						<Image src={TwilioLogo} alt="Twilio" class="w-5 h-5" />
						<h3 class="text-base!">Twilio</h3>
					</div>
					<div class="integration-card">
						<Image src={PagerDutyLogo} alt="PagerDuty" class="w-5 h-5" />
						<h3 class="text-base!">PagerDuty</h3>
					</div>
					<div class="integration-card">
						<Image src={TeamsLogo} alt="Microsoft Teams" class="w-5 h-5" />
						<h3 class="text-base!">Microsoft Teams</h3>
					</div>
					<div class="integration-card">
						<Image src={JiraLogo} alt="Jira" class="w-5 h-5" />
						<h3 class="text-base!">Jira</h3>
					</div>
					<div class="integration-card">
						<Image src={ExaLogo} alt="Exa" class="w-5 h-5" />
						<h3 class="text-base!">Exa</h3>
					</div>
				<div class="integration-card">
					<Image src={TavilyLogo} alt="Tavily" class="w-5 h-5" />
					<h3 class="text-base!">Tavily</h3>
				</div>
				<div class="integration-card">
					<Image src={RestApiLogo} alt="Custom REST API" class="w-5 h-5" />
					<h3 class="text-base!">Custom REST API</h3>
				</div>
				<div class="integration-card">
					<Image src={OpenApiLogo} alt="OpenAPI" class="w-5 h-5" />
					<h3 class="text-base!">OpenAPI</h3>
				</div>
				<div class="integration-card">
					<Image src={SmtpLogo} alt="SMTP" class="w-5 h-5" />
					<h3 class="text-base!">SMTP</h3>
				</div>
				<div class="integration-card">
					<Image src={DatadogLogo} alt="Datadog" class="w-5 h-5" />
					<h3 class="text-base!">Datadog</h3>
				</div>
				<div class="integration-card">
					<Image src={AttioLogo} alt="Attio" class="w-5 h-5" />
					<h3 class="text-base!">Attio</h3>
				</div>
				</div>
			</section>

			<!-- Data Stores -->
			<section>
				<h2 class="text-lg! text-stone-900 dark:text-stone-100 mb-4">Data Stores</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-2">
					<div class="integration-card">
						<Image src={PostgresLogo} alt="PostgreSQL" class="w-5 h-5" />
						<h3 class="text-base!">PostgreSQL</h3>
					</div>
					<div class="integration-card">
						<Image src={MySQLLogo} alt="MySQL" class="w-5 h-5" />
						<h3 class="text-base!">MySQL</h3>
					</div>
					<div class="integration-card">
						<Image src={MSSQLLogo} alt="MSSQL" class="w-5 h-5" />
						<h3 class="text-base!">MSSQL</h3>
					</div>
					<div class="integration-card">
						<Image src={GoogleSheetsLogo} alt="Google Sheets" class="w-5 h-5" />
						<h3 class="text-base!">Google Sheets</h3>
					</div>
					<div class="integration-card">
						<Image src={SnowflakeLogo} alt="Snowflake" class="w-5 h-5" />
						<h3 class="text-base!">Snowflake</h3>
					</div>
					<div class="integration-card">
						<Image src={CouchDBLogo} alt="CouchDB" class="w-5 h-5" />
						<h3 class="text-base!">CouchDB</h3>
					</div>
					<div class="integration-card">
						<Image src={ElasticsearchLogo} alt="Elasticsearch" class="w-5 h-5" />
						<h3 class="text-base!">Elasticsearch</h3>
					</div>
					<div class="integration-card">
						<Image src={MongoDBLogo} alt="MongoDB" class="w-5 h-5" />
						<h3 class="text-base!">MongoDB</h3>
					</div>
					<div class="integration-card">
						<Image src={DynamoDBLogo} alt="DynamoDB" class="w-5 h-5" />
						<h3 class="text-base!">DynamoDB</h3>
					</div>
					<div class="integration-card">
						<Image src={RedisLogo} alt="Redis" class="w-5 h-5" />
						<h3 class="text-base!">Redis</h3>
					</div>
					<div class="integration-card">
						<Image src={OracleLogo} alt="Oracle" class="w-5 h-5" />
						<h3 class="text-base!">Oracle</h3>
					</div>
					<div class="integration-card">
						<Image src={FirestoreLogo} alt="Firestore" class="w-5 h-5" />
						<h3 class="text-base!">Firestore</h3>
					</div>
					<div class="integration-card">
						<Image src={AmazonS3Logo} alt="Amazon S3" class="w-5 h-5" />
						<h3 class="text-base!">Amazon S3</h3>
					</div>
				</div>
			</section>

			<!-- Vector Stores -->
			<section>
				<h2 class="text-lg! text-stone-900 dark:text-stone-100 mb-4">Vector Stores</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-2">
					<div class="integration-card">
						<Image src={PostgresLogo} alt="PGVector" class="w-5 h-5" />
						<h3 class="text-base!">PGVector</h3>
					</div>
				</div>
			</section>
		</div>
	</PlatformLayout>
</Layout>

<style>
	.integration-card {
		background-color: var(--color-stone-100);
		padding: 12px 1rem;
		border-radius: 0.375rem;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.75rem;
	}

	:global(.dark) .integration-card {
		background-color: var(--color-stone-900);
	}

	.integration-card :global(img) {
		filter: grayscale(100%);
	}
</style>
