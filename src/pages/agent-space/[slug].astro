---
import Layout from "../../layouts/MainLayout.astro";
import AccessRequestPrompt from "@components/AccessRequestPrompt.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import {
  coreAgentDetails,
  type CoreAgentDetail,
} from "../../data/agentSpaceCoreAgents";

export async function getStaticPaths() {
  const workflows = await getCollection("workflows");

  const workflowPaths = workflows.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { kind: "workflow", entry },
  }));

  const coreAgentPaths = coreAgentDetails.map((agent) => ({
    params: { slug: agent.slug },
    props: { kind: "core", agent },
  }));

  return [...workflowPaths, ...coreAgentPaths];
}

type WorkflowPageProps = {
  kind: "workflow";
  entry: CollectionEntry<"workflows">;
};

type CorePageProps = {
  kind: "core";
  agent: CoreAgentDetail;
};

const page = Astro.props as WorkflowPageProps | CorePageProps;

let title = "";
let outcome = "";
let workflowSlug: string | null = null;
let WorkflowContent: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let coreAgent: CoreAgentDetail | null = null;
let pageTitle = "";

if (page.kind === "workflow") {
  const { entry } = page;
  title = entry.data.title;
  outcome = entry.data.outcome;
  workflowSlug = entry.data.slug ?? entry.id;
  const rendered = await render(entry);
  WorkflowContent = rendered.Content;
  pageTitle = `${title} Workflow Playbook | Budibase`;
} else {
  coreAgent = page.agent;
  title = coreAgent.title;
  outcome = coreAgent.outcome;
  pageTitle = `${title} Agent | Budibase`;
}
---

<Layout title={pageTitle} description={outcome}>
  <div class="learn-detail-shell">
    <main class="side-rail-main-inner workflow-main pb-20">
      <header class="side-rail-page-header">
        <h1 class="hero-title mb-2 text-5xl!">{title}</h1>
        <p class="text-stone-500! dark:text-stone-400!">{outcome}</p>
        {
          workflowSlug === "access-request" && (
            <div class="mt-4">
              <AccessRequestPrompt collapsible collapsedHeight={200} />
            </div>
          )
        }
      </header>

      <article class="workflow-article">
        {
          WorkflowContent ? (
            <WorkflowContent />
          ) : (
            coreAgent && (
              <>
                <h2 id="overview">Overview</h2>
                {coreAgent.overview.map((paragraph) => <p>{paragraph}</p>)}

                <h2 id="capabilities">Capabilities</h2>
                <ul class="mb-6 list-disc pl-6 text-stone-700 dark:text-stone-300">
                  {coreAgent.capabilities.map((item) => <li>{item}</li>)}
                </ul>

                <h2 id="human-review">Human decision points</h2>
                <ul class="list-disc pl-6 text-stone-700 dark:text-stone-300">
                  {coreAgent.humanReview.map((item) => <li>{item}</li>)}
                </ul>
              </>
            )
          )
        }
      </article>
    </main>
  </div>

  <style>
    .learn-detail-shell {
      width: 100%;
    }

    .workflow-main {
      width: min(100%, 48rem);
      margin-inline: auto;
    }

    .workflow-article :where(h2, h3, h4) {
      scroll-margin-top: calc(var(--site-nav-height) + 24px);
    }

    .workflow-article :where(h2#overview) {
      margin-top: 0 !important;
    }
  </style>

  <script>
    (() => {
      const markerPattern = /\s*\{#([A-Za-z0-9_-]+)\}\s*$/;

      const normalizeHeadingIds = () => {
        const article = document.querySelector("article.workflow-article");
        if (!article) return;
        const headings = Array.from(article.querySelectorAll("h2, h3, h4"));

        headings.forEach((heading) => {
          const text = (heading.textContent || "").trim();
          const markerMatch = text.match(markerPattern);
          if (!markerMatch) return;

          const targetId = markerMatch[1];
          const cleanText = text.replace(markerPattern, "").trim();
          if (cleanText) heading.textContent = cleanText;
          if (targetId) heading.id = targetId;
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", normalizeHeadingIds, {
          once: true,
        });
      } else {
        normalizeHeadingIds();
      }

      document.addEventListener("astro:after-swap", normalizeHeadingIds);
    })();
  </script>
</Layout>
