---
import Layout from "../../layouts/MainLayout.astro";
import AccessRequestPrompt from "@components/AccessRequestPrompt.astro";
import AgentDetailHero from "@components/agent-space/AgentDetailHero.astro";
import AgentPromptPanel from "@components/agent-space/AgentPromptPanel.astro";
import AgentPromptModal from "@components/agent-space/AgentPromptModal.astro";
import AgentAssetsRail from "@components/agent-space/AgentAssetsRail.astro";
import RelatedAgentsSection from "@components/agent-space/RelatedAgentsSection.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { getAgentSpaceCards } from "../../data/agentSpaceCardData";

const DEFAULT_CTA_LABEL = "Use this template";
const DEFAULT_CTA_HREF = "https://account.budibase.app/register";

const ASSET_GROUP_ORDER = [
  { key: "tables", label: "Tables" },
  { key: "automations", label: "Automations" },
  { key: "tools", label: "Tools" },
  { key: "aiModel", label: "AI model" },
  { key: "apps", label: "Apps" },
] as const;

type AssetKey = (typeof ASSET_GROUP_ORDER)[number]["key"];

type AssetBuckets = {
  tables?: string[];
  automations?: string[];
  tools?: string[];
  aiModel?: string[];
  apps?: string[];
};

type ResolvedAssetBuckets = Record<AssetKey, string[]>;

type DetailViewModel = {
  title: string;
  outcome: string;
  slug: string;
  pageTitle: string;
  ctaLabel: string;
  ctaHref: string;
  heroPrompt: string;
  promptCardStyle: "default" | "snippet";
  usePromptCardExperience: boolean;
  useDefaultPromptCard: boolean;
  assetsUsed: ResolvedAssetBuckets;
};

type RelatedAgent = {
  slug: string;
  name: string;
  description: string;
  department: string;
  linkUrl: string;
};

export async function getStaticPaths() {
  const workflows = await getCollection("workflows");

  return workflows.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const uniqueStrings = (items: Array<string | undefined | null>) =>
  Array.from(
    new Set(
      items
        .map((item) => item?.trim())
        .filter((item): item is string => Boolean(item)),
    ),
  );

const mergeAssetsWithFallback = (
  explicitAssets: AssetBuckets | undefined,
  fallbackAssets: AssetBuckets,
): ResolvedAssetBuckets => {
  const merged = {} as ResolvedAssetBuckets;

  for (const group of ASSET_GROUP_ORDER) {
    const explicitItems = explicitAssets?.[group.key] ?? [];
    const fallbackItems = fallbackAssets[group.key] ?? [];
    merged[group.key] = uniqueStrings(
      explicitItems.length > 0 ? explicitItems : fallbackItems,
    );
  }

  return merged;
};

const buildWorkflowPromptFallback = (entry: CollectionEntry<"workflows">) => {
  const assists = entry.data.aiAssists.slice(0, 3).join(", ");
  const humanChecks = entry.data.humansDecide.slice(0, 3).join(", ");

  return [
    `You are orchestrating the \"${entry.data.title}\" workflow for ${entry.data.role}.`,
    `Goal: ${entry.data.outcome}`,
    assists ? `AI assistance: ${assists}.` : "AI assistance: classify, summarize, and route work.",
    humanChecks
      ? `Human decision points: ${humanChecks}.`
      : "Human decision points: exceptions and final approvals.",
    "Keep outputs clear, auditable, and policy-aligned.",
  ].join("\n");
};

const buildWorkflowFallbackAssets = (
  entry: CollectionEntry<"workflows">,
): AssetBuckets => {
  const slug = entry.data.slug ?? entry.id;
  const dataTableSignals = entry.data.integrations.filter((integration) =>
    /(database|erp|hris|accounting|file storage)/i.test(integration),
  );

  return {
    tables: uniqueStrings([
      slug === "access-request" ? "Access Requests" : undefined,
      slug === "access-request" ? "Decisions" : undefined,
      ...dataTableSignals.map((signal) => `${signal} records`),
      entry.data.tags.includes("Human-in-the-loop") ? "Decision audit log" : undefined,
    ]),
    automations: uniqueStrings([
      ...entry.data.steps
        .filter((step) => !step.humanDecision)
        .slice(0, 4)
        .map((step) => step.title),
      entry.data.tags.includes("Automations")
        ? "Event-based workflow routing"
        : undefined,
    ]),
    tools: uniqueStrings(entry.data.integrations),
    aiModel: uniqueStrings([
      slug === "access-request" ? "Ministral-8B-2512" : undefined,
      slug === "access-request" ? "mistralai/mistral-embed-2312" : undefined,
      slug !== "access-request" ? "Configurable LLM provider" : undefined,
    ]),
    apps: uniqueStrings([
      entry.data.tags.includes("Apps") ? "Budibase app interface" : undefined,
      entry.data.tags.includes("Chat") ? "Chat request channel" : undefined,
      "Admin review workspace",
    ]),
  };
};
const { entry } = Astro.props as { entry: CollectionEntry<"workflows"> };
const slug = entry.data.slug ?? entry.id;
const explicitPrompt = entry.data.heroPrompt?.trim() ?? "";
const rendered = await render(entry);
const WorkflowContent = rendered.Content;
const promptCardStyle = entry.data.promptCardStyle ?? "default";
const usePromptCardExperience = promptCardStyle === "snippet";
const useDefaultPromptCard = usePromptCardExperience && slug === "access-request" && !explicitPrompt;

const detail: DetailViewModel = {
  title: entry.data.title,
  outcome: entry.data.outcome,
  slug,
  pageTitle: `${entry.data.title} Workflow Playbook | Budibase`,
  ctaLabel: entry.data.cta?.label?.trim() || DEFAULT_CTA_LABEL,
  ctaHref: entry.data.cta?.href?.trim() || DEFAULT_CTA_HREF,
  heroPrompt: explicitPrompt || buildWorkflowPromptFallback(entry),
  promptCardStyle,
  usePromptCardExperience,
  useDefaultPromptCard,
  assetsUsed: mergeAssetsWithFallback(
    entry.data.assetsUsed,
    buildWorkflowFallbackAssets(entry),
  ),
};

const assetGroups = ASSET_GROUP_ORDER.map((group) => ({
  label: group.label,
  items: detail.assetsUsed[group.key],
}));

const allAgentCards = await getAgentSpaceCards();
const currentAgentCard = allAgentCards.find((card) => card.slug === detail.slug);
const relatedAgents: RelatedAgent[] = allAgentCards
  .filter((card) => card.slug !== detail.slug)
  .sort((a, b) => {
    const aSameDepartment = currentAgentCard
      ? a.departmentId === currentAgentCard.departmentId
      : false;
    const bSameDepartment = currentAgentCard
      ? b.departmentId === currentAgentCard.departmentId
      : false;

    if (aSameDepartment !== bSameDepartment) {
      return aSameDepartment ? -1 : 1;
    }

    return a.name.localeCompare(b.name);
  })
  .slice(0, 3)
  .map((card) => ({
    slug: card.slug,
    name: card.name,
    description: card.description,
    department: card.department,
    linkUrl: card.linkUrl,
  }));
---

<Layout title={detail.pageTitle} description={detail.outcome}>
  <div class="learn-detail-shell">
    <main class="side-rail-main-inner agent-detail-main pb-20">
      <AgentDetailHero
        title={detail.title}
        outcome={detail.outcome}
        ctaLabel={detail.ctaLabel}
        ctaHref={detail.ctaHref}
      >
        {
          detail.usePromptCardExperience ? (
            <AccessRequestPrompt
              collapsible
              collapsedHeight={260}
              promptText={detail.useDefaultPromptCard ? undefined : detail.heroPrompt}
              agentTitle={detail.title}
              toolsUsed={detail.assetsUsed.tools}
              ctaLabel={detail.ctaLabel}
              ctaHref={detail.ctaHref}
            />
          ) : (
            <AgentPromptPanel
              prompt={detail.heroPrompt}
              agentTitle={detail.title}
              toolsUsed={detail.assetsUsed.tools}
              ctaLabel={detail.ctaLabel}
              ctaHref={detail.ctaHref}
            />
          )
        }
      </AgentDetailHero>

      <section class="agent-detail-content-grid">
        <article class="workflow-article agent-detail-article">
          <WorkflowContent />
        </article>

        <AgentAssetsRail groups={assetGroups} />
      </section>

      <RelatedAgentsSection cards={relatedAgents} />
    </main>
  </div>

  <AgentPromptModal
    agentTitle={detail.title}
    toolsUsed={detail.assetsUsed.tools}
    ctaLabel={detail.ctaLabel}
    ctaHref={detail.ctaHref}
    promptText={detail.useDefaultPromptCard ? undefined : detail.heroPrompt}
    useDefaultPrompt={detail.useDefaultPromptCard}
    promptCardStyle={detail.promptCardStyle}
  />

  <style>
    .learn-detail-shell {
      width: 100%;
    }

    .agent-detail-main {
      width: min(100%, 82rem);
      margin-inline: auto;
      padding-top: 0;
    }

    .agent-detail-content-grid {
      display: grid;
      gap: 1rem;
    }

    .agent-detail-article {
      background: var(--bg-1);
      border-radius: 0.8rem;
      padding: 1rem;
      min-width: 0;
    }

    .workflow-article :where(h2, h3, h4) {
      scroll-margin-top: calc(var(--site-nav-height) + 24px);
    }

    .workflow-article :global(h2#overview) {
      margin-top: 0 !important;
    }

    @media (min-width: 768px) {
      .agent-detail-article {
        padding: 1.2rem 1.35rem;
      }
    }

    @media (min-width: 1024px) {
      .agent-detail-content-grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 22rem);
        align-items: start;
      }

      .agent-detail-article {
        padding: 1.25rem 1.5rem;
      }
    }
  </style>

  <script>
    (() => {
      const markerPattern = /\s*\{#([A-Za-z0-9_-]+)\}\s*$/;

      const normalizeHeadingIds = () => {
        const article = document.querySelector("article.workflow-article");
        if (!article) return;
        const headings = Array.from(article.querySelectorAll("h2, h3, h4"));

        headings.forEach((heading) => {
          const text = (heading.textContent || "").trim();
          const markerMatch = text.match(markerPattern);
          if (!markerMatch) return;

          const targetId = markerMatch[1];
          const cleanText = text.replace(markerPattern, "").trim();
          if (cleanText) heading.textContent = cleanText;
          if (targetId) heading.id = targetId;
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", normalizeHeadingIds, {
          once: true,
        });
      } else {
        normalizeHeadingIds();
      }

      document.addEventListener("astro:after-swap", normalizeHeadingIds);
    })();
  </script>
</Layout>
