---
const { frontmatter } = Astro.props;
import "../styles/global.css";
import "../styles/fonts.css";
import Head from "@components/Head.astro";
import bbSymbol from "@assets/logos/BBSymbol.svg";
import { Image } from "astro:assets";
---

<!doctype html>
<html lang="en">
  <Head />
  <body class="py-24 bg-stone-50 dark:bg-stone-950 transition-colors duration-150">
    <div>
      <main>
        <div id="hero" class="opacity: 1; transform: none;">
          <div class="text-base">
            <div class="flex flex-col min-h-screen h-lvh!">
              <div class="max-w-prose mx-auto">
                <a href="/">
                    <div class="w-7 mr-2">
                      <Image
                        src={bbSymbol}
                        alt="Budibase symbol"
                        class="hover:cursor-pointer"
                      />
                    </div>
                  </a>
                <h1 class="mb-4 mt-8">{frontmatter.title}</h1>
                <p class="text-stone-500! dark:text-stone-400!">Written by {frontmatter.author}</p>
                    <slot />
            </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

</style>
